<% 
  # Determine the latest timestamp for polling
  latest_timestamp = @chat.messages.map { |m| m['timestamp'].to_f }.max || 0 
%>

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4 h-[calc(100vh-100px)] min-h-[600px] flex gap-6"
     data-controller="character-chat"
     data-character-chat-character-id-value="<%= @character.id %>"
     data-character-chat-chat-uid-value="<%= @chat.uid %>"
     data-character-chat-latest-timestamp-value="<%= latest_timestamp %>">

  <!-- Left Sidebar (Conversations List) -->
  <div data-character-chat-target="sidebar" class="w-full sm:w-1/3 md:w-1/4 bg-white dark:bg-gray-800 rounded-xl shadow border border-gray-200 dark:border-gray-700 flex-col overflow-hidden hidden sm:flex absolute sm:static inset-0 z-50 sm:z-auto h-full sm:h-auto">
    <div class="p-4 border-b border-gray-200 dark:border-gray-700 flex justify-between items-center bg-gray-50 dark:bg-gray-900">
      <h3 class="font-bold text-gray-900 dark:text-white truncate">Conversations</h3>
      <button data-action="click->character-chat#toggleSidebar" class="sm:hidden text-gray-500 hover:text-gray-700 dark:text-gray-400 dark:hover:text-gray-200 focus:outline-none">
        <i class="material-icons">close</i>
      </button>
    </div>
    <div class="p-4 border-b border-gray-100 dark:border-gray-800">
      <%= link_to character_chats_path(@character), method: :post, class: "w-full flex items-center justify-center px-4 py-2 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-blue-600 hover:bg-blue-700" do %>
        <i class="material-icons text-sm mr-2" style="font-size: 16px;">add</i> New Chat
      <% end %>
    </div>

    <div class="flex-1 overflow-y-auto w-full">
      <ul class="divide-y divide-gray-100 dark:divide-gray-800">
        <% @chats.each do |c| %>
          <% is_active = (c.id == @chat.id) %>
          <li>
            <%= link_to character_chat_path(c.character_id, c.uid), class: "block hover:bg-gray-50 dark:hover:bg-gray-700 transition px-4 py-3 #{is_active ? 'bg-blue-50 dark:bg-blue-900/20 border-l-4 border-blue-500' : ''}" do %>
              <div class="flex items-center space-x-3">
                <div class="flex-shrink-0">
                  <% if c.character.random_image_including_private.present? %>
                    <%= image_tag c.character.random_image_including_private, class: "h-10 w-10 rounded-full object-cover shadow-sm #{is_active ? 'ring-2 ring-blue-500' : ''}" %>
                  <% else %>
                    <div class="h-10 w-10 rounded-full bg-gray-200 dark:bg-gray-700 flex items-center justify-center text-gray-500 font-bold">
                      <%= c.character.name.first.upcase %>
                    </div>
                  <% end %>
                </div>
                <div class="flex-1 min-w-0">
                  <div class="flex justify-between items-baseline mb-1">
                    <p class="text-sm font-medium text-gray-900 dark:text-gray-100 truncate">
                      <%= c.character.name %>
                    </p>
                    <p class="text-xs text-gray-500 dark:text-gray-400 whitespace-nowrap ml-2">
                      <%= time_ago_in_words(c.updated_at).sub('about ', '').sub('less than a minute', 'just now') %>
                    </p>
                  </div>
                  <p class="text-xs text-gray-500 dark:text-gray-400 truncate">
                    <% last_msg = c.messages.reverse.find { |m| m['role'] != 'system' } %>
                    <%= last_msg ? truncate(last_msg['content'], length: 45) : "New Conversation" %>
                  </p>
                </div>
              </div>
            <% end %>
          </li>
        <% end %>
      </ul>
    </div>
  </div>

  <!-- Right Main Area (Chat Interface) -->
  <div class="flex-1 bg-gray-50 dark:bg-gray-900 rounded-xl shadow border border-gray-200 dark:border-gray-700 flex flex-col relative overflow-hidden">
    
    <!-- Header -->
    <div class="bg-white dark:bg-gray-800 px-6 py-4 border-b border-gray-200 dark:border-gray-700 flex items-center justify-between shadow-sm z-10">
      <div class="flex items-center space-x-3">
        <button data-action="click->character-chat#toggleSidebar" class="sm:hidden text-gray-500 hover:text-blue-600 focus:outline-none mr-2">
          <i class="material-icons">menu</i>
        </button>
        <%= image_tag @character.random_image_including_private, class: "h-10 w-10 rounded-full object-cover shadow-sm" if @character.random_image_including_private.present? %>
        <div>
          <h2 class="text-lg font-bold text-gray-900 dark:text-white capitalize">
            <%= @character.name %>
          </h2>
          <p class="text-xs text-green-500 font-medium">Online</p>
        </div>
      </div>
      
      <div class="flex items-center">
        <!-- Delete Conversation Button -->
        <%= link_to character_chat_path(@character, @chat.uid), method: :delete, data: { confirm: "Are you sure you want to delete this conversation?", tooltip: "Delete Conversation", position: "bottom" }, class: "text-gray-400 hover:text-red-500 transition tooltipped" do %>
          <i class="material-icons">delete_outline</i>
        <% end %>
      </div>
    </div>

    <!-- Messages -->
    <div class="flex-1 p-6 overflow-y-auto space-y-4" data-character-chat-target="messages">
      <% @chat.messages.each do |msg| %>
        <% next if msg['role'] == 'system' && !msg['content'].include?('Error') %>
        
        <div class="flex w-full mb-4 <%= msg['role'] == 'user' ? 'justify-end' : 'justify-start' %>">
          <% if msg['role'] == 'user' %>
            <div class="bg-blue-600 text-white rounded-2xl rounded-br-sm px-4 py-2 max-w-[80%] whitespace-pre-wrap"><%= msg['content'] %></div>
          <% elsif msg['role'] == 'ai' %>
            <div class="bg-white dark:bg-gray-800 text-gray-900 dark:text-gray-100 border border-gray-200 dark:border-gray-700 shadow-sm rounded-2xl rounded-bl-sm px-4 py-2 max-w-[80%] whitespace-pre-wrap"><%= msg['content'] %></div>
          <% else %>
            <div class="bg-red-50 text-red-600 rounded-2xl px-4 py-2 max-w-[80%] italic text-sm text-center mx-auto"><%= msg['content'] %></div>
          <% end %>
        </div>
      <% end %>
    </div>

    <!-- Input Area -->
    <div class="bg-white dark:bg-gray-800 p-4 border-t border-gray-200 dark:border-gray-700 z-10">
      <form data-character-chat-target="form" data-action="submit->character-chat#submit" class="flex space-x-3 items-end">
        <div class="flex-1 relative">
          <textarea 
            data-character-chat-target="input" 
            data-action="keydown->character-chat#submit"
            rows="1" 
            placeholder="Type a message to <%= @character.name %>..." 
            class="block w-full rounded-2xl border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm pl-4 pr-12 py-3 resize-none dark:bg-gray-900 dark:text-white dark:border-gray-700" 
            style="max-height: 120px; overflow-y: auto;"></textarea>
        </div>
        <button type="submit" data-character-chat-target="submitBtn" class="flex-shrink-0 inline-flex items-center justify-center h-11 w-11 border border-transparent rounded-full shadow-sm text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 transition-colors cursor-pointer disabled:opacity-50 disabled:cursor-not-allowed">
          <i class="material-icons text-xl">send</i>
        </button>
      </form>
      <div class="text-center mt-2">
        <p class="text-xs text-gray-400 dark:text-gray-500">Press <kbd class="px-1 py-0.5 border border-gray-200 dark:border-gray-700 rounded text-gray-500 dark:text-gray-400">Enter</kbd> to send, <kbd class="px-1 py-0.5 border border-gray-200 dark:border-gray-700 rounded text-gray-500 dark:text-gray-400">Shift</kbd> + <kbd class="px-1 py-0.5 border border-gray-200 dark:border-gray-700 rounded text-gray-500 dark:text-gray-400">Enter</kbd> for new line</p>
      </div>
    </div>

  </div>
</div>
