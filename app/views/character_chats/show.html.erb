<% 
  # Determine the latest timestamp for polling
  latest_timestamp = @chat.messages.map { |m| m['timestamp'].to_f }.max || 0 
%>

<div class="bg-gray-50 dark:bg-gray-900 pt-10 flex flex-col min-h-screen"
     data-controller="character-chat"
     data-character-chat-character-id-value="<%= @character.id %>"
     data-character-chat-chat-uid-value="<%= @chat.uid %>"
     data-character-chat-latest-timestamp-value="<%= latest_timestamp %>">

  <!-- Breadcrumbs Bar (Mocking content/header) -->
  <nav class="bg-white dark:bg-gray-800 py-1.5 border-b border-gray-200 dark:border-gray-700 flex fixed top-14 left-0 right-0 z-40 -mt-px transition-all duration-300" :class="{ 'md:ml-56': showSidebar && isDesktop, 'md:ml-16': !showSidebar && isDesktop, 'ml-0': !isDesktop }" aria-label="Breadcrumb">
    <ol role="list" class="flex mx-auto px-4 space-x-4 sm:px-6 lg:px-8 w-full items-center">
      <li class="flex">
        <%= link_to root_path, class: 'text-gray-400 hover:text-gray-500' do %>
          <i class="material-icons flex-shrink-0 text-lg">dashboard</i>
        <% end %>
      </li>
      <li class="hidden sm:flex">
        <div class="flex items-center">
          <svg class="flex-shrink-0 w-4 h-5 text-gray-200 dark:text-gray-600" viewBox="0 0 24 44" preserveAspectRatio="none" fill="currentColor"><path d="M.293 0l22 22-22 22h1.414l22-22-22-22H.293z" /></svg>
          <%= link_to 'Characters', characters_path, class: 'ml-4 text-sm font-medium text-gray-500 hover:text-gray-700 dark:hover:text-white' %>
        </div>
      </li>
      <li class="flex">
        <div class="flex items-center">
          <svg class="flex-shrink-0 w-4 h-5 text-gray-200 dark:text-gray-600" viewBox="0 0 24 44" preserveAspectRatio="none" fill="currentColor"><path d="M.293 0l22 22-22 22h1.414l22-22-22-22H.293z" /></svg>
          <%= link_to @character.name, character_path(@character), class: 'ml-4 text-sm font-medium text-gray-500 hover:text-gray-700 dark:hover:text-white truncate max-w-[120px] sm:max-w-none' %>
        </div>
      </li>
      <li class="flex">
        <div class="flex items-center">
          <svg class="flex-shrink-0 w-4 h-5 text-gray-200 dark:text-gray-600" viewBox="0 0 24 44" preserveAspectRatio="none" fill="currentColor"><path d="M.293 0l22 22-22 22h1.414l22-22-22-22H.293z" /></svg>
          <span class="ml-4 text-sm font-medium text-gray-900 dark:text-white" aria-current="page">Chat Interface</span>
        </div>
      </li>
    </ol>
  </nav>

  <!-- Hero Image Header -->
  <div class="relative h-64 md:h-80 lg:h-96 bg-gray-900 overflow-hidden flex-shrink-0 mt-4 md:mt-0 transition-all duration-300">
    <% if @character.random_image_including_private.present? %>
      <%= image_tag @character.random_image_including_private, class: "w-full h-full object-cover opacity-80" %>
    <% else %>
      <%= image_tag "card-headers/characters.jpg", class: "w-full h-full object-cover opacity-80" %>
    <% end %>
    
    <!-- Content overlay with solid background -->
    <div class="absolute bottom-0 left-0 right-0 p-6 lg:p-8">
      <div class="max-w-4xl mx-auto">
        <!-- Sophisticated header container -->
        <div class="bg-notebook-blue bg-opacity-60 backdrop-blur-xl rounded-2xl px-4 py-3 border border-white border-opacity-20 shadow-2xl inline-block max-w-full">
          <div class="flex items-center space-x-4">
            <!-- Premium page icon -->
            <div class="flex-shrink-0 hidden sm:block">
              <div class="w-12 h-12 <%= Character.color rescue 'bg-red-500' %> rounded-xl flex items-center justify-center shadow-lg ring-2 ring-white ring-opacity-20">
                <i class="material-icons text-white text-xl font-light"><%= Character.icon rescue 'person' %></i>
              </div>
            </div>
            
            <!-- Enhanced typography section -->
            <div class="flex-1 min-w-0 pr-4">
              <h1 class="text-xl lg:text-3xl font-bold text-white truncate tracking-tight leading-tight drop-shadow-md">
                <%= @character.name %>
              </h1>
              
              <% if @character.universe.present? %>
                <div class="mt-2">
                  <span class="inline-flex items-center text-white <%= Universe.color rescue 'bg-purple-500' %> px-3 py-1 rounded-full text-xs font-semibold shadow-sm tracking-wide">
                    <i class="material-icons text-xs mr-1"><%= Universe.icon rescue 'public' %></i>
                    <%= @character.universe.name %>
                  </span>
                </div>
              <% end %>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Main responsive layout matching content/show -->
  <div class="max-w-full mx-auto w-full transition-all duration-300">
    <div class="flex min-h-[calc(100vh-28rem)] relative">
      
      <!-- Left Column - Navigation Sidebar (Conversations) -->
      <div class="hidden lg:block w-72 bg-white dark:bg-gray-800 border-r border-gray-200 dark:border-gray-700 shadow-sm flex-shrink-0 self-start z-10 sticky top-[7.5rem]" style="height: calc(100vh - 7.5rem);">
        <div class="p-4 border-b border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-900 border-t-4 border-t-red-500">
          <h3 class="font-bold text-gray-900 dark:text-white uppercase tracking-wider text-xs">Conversations Panel</h3>
        </div>
        <div class="p-3 border-b border-gray-100 dark:border-gray-800">
          <%= link_to character_chats_path(@character), method: :post, class: "w-full flex items-center justify-center px-4 py-2 border border-blue-500 shadow-sm text-sm font-medium rounded-md text-blue-600 bg-blue-50 hover:bg-blue-100 dark:bg-blue-900/30 dark:text-blue-400 dark:hover:bg-blue-900 transition-colors" do %>
            <i class="material-icons text-sm mr-2" style="font-size: 16px;">add</i> Start New Thread
          <% end %>
        </div>

        <div class="overflow-y-auto h-full pb-32">
          <ul class="divide-y divide-gray-100 dark:divide-gray-800">
            <% @chats.each do |c| %>
              <% is_active = (c.id == @chat.id) %>
              <li>
                <%= link_to character_chat_path(c.character_id, c.uid), class: "block hover:bg-gray-50 dark:hover:bg-gray-700 transition px-4 py-3 #{is_active ? 'bg-red-50 dark:bg-red-900/20 border-l-4 border-red-500' : ''}" do %>
                  <div class="flex items-center space-x-3">
                    <div class="flex-shrink-0">
                      <% if c.character.random_image_including_private.present? %>
                        <%= image_tag c.character.random_image_including_private, class: "h-10 w-10 rounded-full object-cover shadow-sm #{is_active ? 'ring-2 ring-red-500' : ''}" %>
                      <% else %>
                        <div class="h-10 w-10 rounded-full bg-gray-200 dark:bg-gray-700 flex items-center justify-center text-gray-500 font-bold">
                          <%= c.character.name.first.upcase %>
                        </div>
                      <% end %>
                    </div>
                    <div class="flex-1 min-w-0">
                      <p class="text-sm font-semibold text-gray-900 dark:text-gray-100 truncate <%= is_active ? 'text-red-700 dark:text-red-400' : '' %>">
                        <%= c.character.name %>
                      </p>
                      <p class="text-xs text-gray-400 dark:text-gray-500 truncate mt-0.5 lowercase font-medium">
                        <%= time_ago_in_words(c.updated_at).sub('about ', '').sub('less than a minute', 'now') %>
                      </p>
                    </div>
                  </div>
                <% end %>
              </li>
            <% end %>
          </ul>
        </div>
      </div>

      <!-- Center Column - Dynamic Content (Chat UI) -->
      <div class="flex-1 bg-white dark:bg-gray-900 border-l border-gray-200 dark:border-gray-700 flex flex-col relative min-w-0 min-h-full pb-32">
        
        <!-- Mobile Sidebar Toggle -->
        <div class="lg:hidden p-4 border-b border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-900 flex justify-between items-center sticky top-24 z-20 shadow-sm">
          <button data-action="click->character-chat#toggleSidebar" class="flex items-center text-gray-600 dark:text-gray-300 font-medium text-sm hover:text-red-600 transition-colors">
            <i class="material-icons mr-2">menu_open</i>
            View Conversations (<%= @chats.count %>)
          </button>
          
          <div class="flex items-center">
            <%= link_to character_chat_path(@character, @chat.uid), method: :delete, data: { confirm: "Are you sure you want to delete this conversation?", tooltip: "Delete Conversation", position: "bottom" }, class: "text-gray-400 hover:text-red-500 transition tooltipped" do %>
              <i class="material-icons">delete_outline</i>
            <% end %>
          </div>
        </div>

        <!-- Chat Header (Desktop) -->
        <div class="hidden lg:flex items-center justify-between px-8 py-4 bg-white dark:bg-gray-900 border-b border-gray-100 dark:border-gray-800">
          <div class="flex items-center">
            <h2 class="text-lg font-bold text-gray-900 dark:text-gray-100">Live Chat</h2>
            <span class="ml-3 inline-flex items-center px-2 py-0.5 rounded-full text-xs font-semibold bg-green-100 text-green-800 border border-green-200 shadow-sm">
              <span class="w-2 h-2 rounded-full bg-green-500 mr-1.5 animate-pulse"></span>
              Online
            </span>
          </div>
          <div class="flex items-center">
            <%= link_to character_chat_path(@character, @chat.uid), method: :delete, data: { confirm: "Are you sure you want to delete this conversation?", tooltip: "Delete Conversation", position: "bottom" }, class: "text-gray-400 hover:text-red-500 transition tooltipped flex items-center justify-center p-2 rounded-lg hover:bg-red-50 dark:hover:bg-red-900/20" do %>
              <i class="material-icons text-xl">delete_outline</i>
            <% end %>
          </div>
        </div>

        <!-- Messages Area -->
        <div class="flex-1 p-4 lg:p-8 space-y-3" data-character-chat-target="messages">
          <% @chat.messages.each do |msg| %>
            <% next if msg['role'] == 'system' && !msg['content'].include?('Error') %>
            
            <div class="flex w-full items-end <%= msg['role'] == 'user' ? 'justify-end pl-12' : 'justify-start pr-12' %>">
              <% if msg['role'] == 'user' %>
                <div class="bg-blue-600 text-white rounded-2xl px-4 py-2.5 shadow-sm whitespace-pre-wrap text-sm sm:text-base leading-snug relative group break-words max-w-sm lg:max-w-md xl:max-w-lg inline-block"><%= msg['content'].strip %><div class="absolute -right-2 -bottom-2 w-4 h-4 text-blue-600 hidden group-hover:block transition-all"><i class="material-icons text-sm">done_all</i></div></div>
              <% elsif msg['role'] == 'ai' %>
                <div class="flex items-end space-x-3 w-full">
                  <% if @character.random_image_including_private.present? %>
                    <%= image_tag @character.random_image_including_private, class: "h-8 w-8 rounded-full object-cover shadow-sm mb-1 hidden sm:block ring-1 ring-gray-200 dark:ring-gray-700 flex-shrink-0" %>
                  <% end %>
                  <div class="bg-white dark:bg-gray-800 text-gray-800 dark:text-gray-200 border border-gray-200 dark:border-gray-700 shadow-sm rounded-2xl px-4 py-2.5 whitespace-pre-wrap break-words text-sm sm:text-base leading-snug max-w-sm lg:max-w-md xl:max-w-lg inline-block"><%= msg['content'].strip %></div>
                </div>
              <% else %>
                <div class="bg-red-50 border border-red-100 text-red-600 rounded-xl px-4 py-2 mx-auto shadow-sm flex items-center text-sm font-medium">
                  <i class="material-icons text-red-500 mr-2 text-lg">error_outline</i>
                  <%= msg['content'].strip %>
                </div>
              <% end %>
            </div>
          <% end %>
        </div>

        <!-- Input Area (Sticky to bottom of screen) -->
        <div class="sticky bottom-0 w-full bg-white dark:bg-gray-900 p-4 lg:p-6 border-t border-gray-200 dark:border-gray-800 z-30 shadow-[0_-10px_15px_-3px_rgba(0,0,0,0.03)]">
          <form data-character-chat-target="form" data-action="submit->character-chat#submit" class="flex flex-col space-y-2 w-full mx-auto max-w-4xl">
            <div class="relative flex items-end bg-white dark:bg-gray-800 rounded-3xl border border-gray-300 dark:border-gray-600 shadow-sm focus-within:ring-2 focus-within:ring-blue-500 focus-within:border-transparent transition-all overflow-hidden">
              <textarea 
                data-character-chat-target="input" 
                data-action="keydown->character-chat#submit"
                rows="1" 
                placeholder="Message <%= @character.name %>..." 
                class="block w-full bg-transparent border-0 text-gray-900 dark:text-white text-sm sm:text-base pl-5 pr-14 py-3.5 resize-none focus:ring-0" 
                style="max-height: 160px; overflow-y: auto; outline: none; box-shadow: none;"></textarea>
              
              <button type="submit" data-character-chat-target="submitBtn" class="absolute right-1 bottom-1 flex-shrink-0 inline-flex items-center justify-center h-10 w-10 rounded-full shadow-sm text-white bg-blue-600 hover:bg-blue-700 hover:shadow-md focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 transition-all cursor-pointer disabled:opacity-50 disabled:cursor-not-allowed">
                <i class="material-icons text-xl ml-0.5">arrow_upward</i>
              </button>
            </div>
            <div class="text-center px-4 hidden sm:block">
              <p class="text-[11px] text-gray-400 dark:text-gray-500 tracking-wide font-medium">Press <kbd class="px-1.5 py-0.5 border border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-800 rounded mx-1">Enter</kbd> to send or <kbd class="px-1.5 py-0.5 border border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-800 rounded mx-1">Shift</kbd> + <kbd class="px-1.5 py-0.5 border border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-800 rounded mx-1">Enter</kbd> to add a new line</p>
            </div>
          </form>
        </div>

      </div>
      
    </div>
  </div>

  <!-- Mobile/Tablet Left Sidebar Toggle Overlay -->
  <div data-character-chat-target="sidebar" class="hidden fixed inset-0 z-50 flex" x-cloak>
    <div class="fixed inset-0 bg-black bg-opacity-60 transition-opacity backdrop-blur-sm" data-action="click->character-chat#toggleSidebar"></div>
    <div class="relative flex-1 flex flex-col max-w-xs w-full bg-white dark:bg-gray-800 shadow-2xl">
      <div class="absolute top-0 right-0 -mr-12 pt-2">
        <button data-action="click->character-chat#toggleSidebar" class="ml-1 flex items-center justify-center h-10 w-10 rounded-full focus:outline-none focus:ring-2 focus:ring-inset focus:ring-white">
          <i class="material-icons text-white">close</i>
        </button>
      </div>
      <div class="p-4 border-b border-gray-200 dark:border-gray-700 flex justify-between items-center bg-red-600 text-white">
        <h3 class="font-bold truncate text-lg">Conversations</h3>
      </div>
      <div class="p-4 border-b border-gray-100 dark:border-gray-800 bg-gray-50 dark:bg-gray-900">
        <%= link_to character_chats_path(@character), method: :post, class: "w-full flex items-center justify-center px-4 py-2 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-blue-600 hover:bg-blue-700" do %>
          <i class="material-icons text-sm mr-2">add</i> New Chat
        <% end %>
      </div>
      <div class="flex-1 overflow-y-auto w-full pb-10">
        <ul class="divide-y divide-gray-100 dark:divide-gray-800">
          <% @chats.each do |c| %>
            <% is_active = (c.id == @chat.id) %>
            <li>
              <%= link_to character_chat_path(c.character_id, c.uid), class: "block hover:bg-gray-50 dark:hover:bg-gray-700 transition px-4 py-4 #{is_active ? 'bg-red-50 dark:bg-red-900/20 border-l-4 border-red-500' : ''}" do %>
                <div class="flex items-center space-x-4">
                  <div class="flex-shrink-0">
                    <% if c.character.random_image_including_private.present? %>
                      <%= image_tag c.character.random_image_including_private, class: "h-12 w-12 rounded-full object-cover shadow-sm #{is_active ? 'ring-2 ring-red-500' : ''}" %>
                    <% else %>
                      <div class="h-12 w-12 rounded-full bg-gray-200 flex items-center justify-center text-gray-500 font-bold text-lg">
                        <%= c.character.name.first.upcase %>
                      </div>
                    <% end %>
                  </div>
                  <div class="flex-1 min-w-0">
                    <p class="text-base font-semibold text-gray-900 dark:text-gray-100 truncate <%= is_active ? 'text-red-700 dark:text-red-400' : '' %>">
                      <%= c.character.name %>
                    </p>
                    <p class="text-xs text-gray-400 dark:text-gray-500 truncate mt-0.5 lowercase font-medium">
                      <%= time_ago_in_words(c.updated_at).sub('about ', '').sub('less than a minute', 'now') %>
                    </p>
                  </div>
                </div>
              <% end %>
            </li>
          <% end %>
        </ul>
      </div>
    </div>
  </div>

</div>
