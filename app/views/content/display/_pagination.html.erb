<div class="bg-white dark:bg-gray-800 border-t border-gray-200 dark:border-gray-700 px-6 lg:px-8 py-4">
  <div class="flex items-center justify-between">
    <div class="flex-1 flex justify-between sm:hidden">
      <!-- Mobile pagination -->
      <% if (@current_page || 1) > 1 %>
        <%= link_to url_for(params.permit(:sort, :slug, :favorite_only).merge({ page: (@current_page || 1) - 1 })), class: "relative inline-flex items-center px-4 py-2 text-sm font-medium rounded-md text-gray-700 dark:text-gray-200 bg-white dark:bg-gray-700 border border-gray-300 dark:border-gray-600 hover:bg-gray-50 dark:hover:bg-gray-600" do %>
          Previous
        <% end %>
      <% else %>
        <span class="relative inline-flex items-center px-4 py-2 text-sm font-medium rounded-md text-gray-400 dark:text-gray-500 bg-gray-100 dark:bg-gray-800 border border-gray-300 dark:border-gray-600 cursor-not-allowed">
          Previous
        </span>
      <% end %>

      <% if (@current_page || 1) < (@total_pages || 1) %>
        <%= link_to url_for(params.permit(:sort, :slug, :favorite_only).merge({ page: (@current_page || 1) + 1 })), class: "ml-3 relative inline-flex items-center px-4 py-2 text-sm font-medium rounded-md text-gray-700 dark:text-gray-200 bg-white dark:bg-gray-700 border border-gray-300 dark:border-gray-600 hover:bg-gray-50 dark:hover:bg-gray-600" do %>
          Next
        <% end %>
      <% else %>
        <span class="ml-3 relative inline-flex items-center px-4 py-2 text-sm font-medium rounded-md text-gray-400 dark:text-gray-500 bg-gray-100 dark:bg-gray-800 border border-gray-300 dark:border-gray-600 cursor-not-allowed">
          Next
        </span>
      <% end %>
    </div>

    <div class="hidden sm:flex-1 sm:flex sm:items-center sm:justify-between">
      <div>
        <p class="text-sm text-gray-700 dark:text-gray-300">
          Showing
          <span class="font-medium"><%= ((@current_page || 1) - 1) * 50 + 1 %></span>
          to
          <span class="font-medium"><%= [(@current_page || 1) * 50, (@total_content_count || 0)].min %></span>
          of
          <span class="font-medium"><%= @total_content_count %></span>
          results
        </p>
      </div>
      <div>
        <nav class="relative z-0 inline-flex rounded-md shadow-sm -space-x-px" aria-label="Pagination">
          <!-- Previous button -->
          <% if (@current_page || 1) > 1 %>
            <%= link_to url_for(params.permit(:sort, :slug, :favorite_only).merge({ page: (@current_page || 1) - 1 })), class: "relative inline-flex items-center px-2 py-2 rounded-l-md border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-sm font-medium text-gray-500 dark:text-gray-400 hover:bg-gray-50 dark:hover:bg-gray-600" do %>
              <span class="sr-only">Previous</span>
              <i class="material-icons text-lg">chevron_left</i>
            <% end %>
          <% else %>
            <span class="relative inline-flex items-center px-2 py-2 rounded-l-md border border-gray-300 dark:border-gray-600 bg-gray-100 dark:bg-gray-800 text-sm font-medium text-gray-400 dark:text-gray-500 cursor-not-allowed">
              <span class="sr-only">Previous</span>
              <i class="material-icons text-lg">chevron_left</i>
            </span>
          <% end %>

          <!-- Page numbers -->
          <%
            start_page = [(@current_page || 1) - 2, 1].max
            end_page = [start_page + 4, (@total_pages || 1)].min
            start_page = [end_page - 4, 1].max
          %>

          <% (start_page..end_page).each do |page_num| %>
            <% if page_num == (@current_page || 1) %>
              <span class="relative inline-flex items-center px-4 py-2 border border-gray-300 dark:border-gray-600 bg-blue-50 dark:bg-blue-900 text-sm font-medium text-blue-600 dark:text-blue-400">
                <%= page_num %>
              </span>
            <% else %>
              <%= link_to page_num, url_for(params.permit(:sort, :slug, :favorite_only).merge({ page: page_num })), class: "relative inline-flex items-center px-4 py-2 border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-sm font-medium text-gray-700 dark:text-gray-200 hover:bg-gray-50 dark:hover:bg-gray-600" %>
            <% end %>
          <% end %>

          <!-- Next button -->
          <% if (@current_page || 1) < (@total_pages || 1) %>
            <%= link_to url_for(params.permit(:sort, :slug, :favorite_only).merge({ page: (@current_page || 1) + 1 })), class: "relative inline-flex items-center px-2 py-2 rounded-r-md border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-sm font-medium text-gray-500 dark:text-gray-400 hover:bg-gray-50 dark:hover:bg-gray-600" do %>
              <span class="sr-only">Next</span>
              <i class="material-icons text-lg">chevron_right</i>
            <% end %>
          <% else %>
            <span class="relative inline-flex items-center px-2 py-2 rounded-r-md border border-gray-300 dark:border-gray-600 bg-gray-100 dark:bg-gray-800 text-sm font-medium text-gray-400 dark:text-gray-500 cursor-not-allowed">
              <span class="sr-only">Next</span>
              <i class="material-icons text-lg">chevron_right</i>
            </span>
          <% end %>
        </nav>
      </div>
    </div>
  </div>
</div>
