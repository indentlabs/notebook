<% content_for :thredded_main_navigation do %>
  <nav class="thredded--moderation-navigation border-b border-slate-200 dark:border-slate-700 mb-6 pb-2">
    <ul class="thredded--moderation-navigation--items flex flex-wrap gap-4 sm:gap-6 text-sm font-medium text-center text-slate-500 dark:text-slate-400">
      <li class="thredded--moderation-navigation--item thredded--moderation-navigation--pending">
        <%= link_to pending_moderation_path, 
                    class: "inline-flex items-center p-2 border-b-2 rounded-t-lg transition-colors #{current_page?(pending_moderation_path) ? 'active text-blue-600 border-blue-600 dark:text-blue-500 dark:border-blue-500' : 'border-transparent hover:text-slate-600 hover:border-slate-300 dark:hover:text-slate-300'}",
                    'aria-current': (current_page?(pending_moderation_path) ? 'page' : nil) do %>
          <i class="material-icons" style="font-size: 16px; margin-right: 6px;">pending_actions</i>
          <%= t('thredded.nav.moderation_pending') %>
        <% end %>
      </li>
      <li class="thredded--moderation-navigation--item thredded--moderation-navigation--history">
        <%= link_to moderation_history_path,
                    class: "inline-flex items-center p-2 border-b-2 rounded-t-lg transition-colors #{current_page?(moderation_history_path) ? 'active text-blue-600 border-blue-600 dark:text-blue-500 dark:border-blue-500' : 'border-transparent hover:text-slate-600 hover:border-slate-300 dark:hover:text-slate-300'}",
                    'aria-current': (current_page?(moderation_history_path) ? 'page' : nil) do %>
          <i class="material-icons" style="font-size: 16px; margin-right: 6px;">history</i>
          <%= t('thredded.nav.moderation_history') %>
        <% end %>
      </li>
      <li class="thredded--moderation-navigation--item thredded--moderation-navigation--activity">
        <%= link_to moderation_activity_path,
                    class: "inline-flex items-center p-2 border-b-2 rounded-t-lg transition-colors #{current_page?(moderation_activity_path) ? 'active text-blue-600 border-blue-600 dark:text-blue-500 dark:border-blue-500' : 'border-transparent hover:text-slate-600 hover:border-slate-300 dark:hover:text-slate-300'}",
                    'aria-current': (current_page?(moderation_activity_path) ? 'page' : nil) do %>
          <i class="material-icons" style="font-size: 16px; margin-right: 6px;">timeline</i>
          <%= t('thredded.nav.moderation_activity') %>
        <% end %>
      </li>
      <li class="thredded--moderation-navigation--item thredded--moderation-navigation--users">
        <%= link_to users_moderation_path,
                    class: "inline-flex items-center p-2 border-b-2 rounded-t-lg transition-colors #{current_page?(users_moderation_path) ? 'active text-blue-600 border-blue-600 dark:text-blue-500 dark:border-blue-500' : 'border-transparent hover:text-slate-600 hover:border-slate-300 dark:hover:text-slate-300'}",
                    'aria-current': (current_page?(users_moderation_path) ? 'page' : nil) do %>
          <i class="material-icons" style="font-size: 16px; margin-right: 6px;">group</i>
          <%= t('thredded.nav.moderation_users') %>
        <% end %>
      </li>
    </ul>
  </nav>
<% end %>