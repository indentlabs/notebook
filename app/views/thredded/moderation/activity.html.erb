<% content_for :thredded_page_title, t('thredded.nav.moderation') %>
<% content_for :thredded_page_id, 'thredded--moderation-activity' %>
<%= render 'nav' %>

<%= thredded_page do %>
  <div class="thredded--main-section mt-6">
    <!-- Activity Header -->
    <div class="activity-header mb-8 pb-4 border-b border-slate-200 dark:border-slate-700">
      <div class="activity-title flex items-center text-2xl font-bold dark:text-white">
        <i class="material-icons text-3xl mr-3 text-slate-400 dark:text-slate-500">timeline</i>
        <h2><%= t 'thredded.recent_activity' %></h2>
      </div>
    </div>
    
    <!-- Last Moderated Notice -->
    <% if @last_moderated_record %>
      <div class="thredded--moderated-notice bg-emerald-50 dark:bg-emerald-900/30 border border-emerald-200 dark:border-emerald-800 text-emerald-800 dark:text-emerald-300 p-4 rounded-lg mb-8 flex justify-between items-start shadow-sm transition-all">
        <div class="flex">
          <i class="material-icons text-emerald-500 mr-3 mt-0.5">check_circle</i>
          <div class="notice-content">
            <div class="notice-title font-bold mb-1">Recently moderated</div>
            <div class="notice-text text-sm">
              <%= render_post_moderation_records([@last_moderated_record]) %>
            </div>
          </div>
        </div>
        <button class="notice-dismiss text-emerald-600 dark:text-emerald-400 hover:text-emerald-800 dark:hover:text-emerald-200 transition-colors p-1" onclick="this.parentElement.style.display='none'">
          <i class="material-icons text-sm">close</i>
        </button>
      </div>
    <% end %>
    
    <!-- Activity Feed -->
    <% if @posts.present? %>
      <div class="activity-feed bg-white dark:bg-slate-800 rounded-lg shadow-sm border border-slate-200 dark:border-slate-700 overflow-hidden mb-8">
        <div class="feed-header px-6 py-4 border-b border-slate-200 dark:border-slate-700 bg-slate-50/50 dark:bg-slate-800/80">
          <h3 class="flex items-center text-lg font-semibold text-slate-800 dark:text-slate-200">
            <i class="material-icons mr-2 text-slate-400">forum</i>
            Recent Forum Activity
          </h3>
        </div>
        
        <div class="feed-items divide-y divide-slate-100 dark:divide-slate-700">
          <% @posts.each do |post| %>
            <div class="feed-item p-6 flex flex-col sm:flex-row gap-4 hover:bg-slate-50 dark:hover:bg-slate-800/50 transition-colors">
              <div class="feed-item-indicator hidden sm:flex shrink-0 w-10 h-10 rounded-full items-center justify-center <%= post.to_model.first_post_in_topic? ? 'bg-blue-100 text-blue-600 dark:bg-blue-900/30 dark:text-blue-400' : 'bg-slate-100 text-slate-500 dark:bg-slate-700 dark:text-slate-400' %>">
                <% if post.to_model.first_post_in_topic? %>
                  <i class="material-icons text-xl">add_comment</i>
                <% else %>
                  <i class="material-icons text-xl">reply</i>
                <% end %>
              </div>
              
              <div class="feed-item-content flex-grow min-w-0">
                <div class="feed-meta flex flex-wrap items-center gap-1.5 text-sm text-slate-600 dark:text-slate-400 mb-2">
                  <% if post.user %>
                    <%= image_tag post.user.image_url(size: 40), class: 'feed-avatar w-6 h-6 rounded-full inline-block' %>
                    <span class="feed-user font-medium text-slate-900 dark:text-slate-200"><%= user_link post.user %></span>
                  <% else %>
                    <span class="feed-user font-medium text-slate-900 dark:text-slate-200">Anonymous</span>
                  <% end %>
                  <span class="feed-action">
                    <% if post.to_model.first_post_in_topic? %>
                      started a new topic
                    <% else %>
                      replied
                    <% end %>
                  </span>
                  <span class="feed-location">
                    <% topic = post.to_model.postable %>
                    in <%= link_to truncate(topic.title, length: 50), topic_path(topic), class: 'feed-topic-link font-medium text-blue-600 dark:text-blue-400 hover:underline' %>
                  </span>
                  <span class="text-slate-300 dark:text-slate-600 mx-1">•</span>
                  <span class="feed-time whitespace-nowrap">
                    <%= time_ago post.created_at %>
                  </span>
                </div>
                
                <div class="feed-preview text-slate-700 dark:text-slate-300 bg-slate-50/50 dark:bg-slate-900/30 p-3 rounded-md border border-slate-100 dark:border-slate-700/50 text-sm mb-3">
                  <%= truncate(strip_tags(post.filtered_content(self)), length: 200) %>
                </div>
                
                <div class="feed-actions flex items-center gap-3">
                  <a href="<%= post.permalink_path %>" class="feed-action-btn flex items-center text-sm font-medium text-blue-600 hover:text-blue-700 dark:text-blue-400 dark:hover:text-blue-300">
                    <i class="material-icons text-[18px] mr-1">visibility</i>
                    View
                  </a>
                  
                  <% if post.can_update? %>
                    <%= link_to post.edit_path, class: 'feed-action-btn flex items-center text-sm font-medium text-slate-500 hover:text-slate-700 dark:text-slate-400 dark:hover:text-slate-300' do %>
                      <i class="material-icons text-[18px] mr-1">edit</i>
                      Edit
                    <% end %>
                  <% end %>
                  
                  <% if post.can_moderate? %>
                    <button class="feed-action-btn moderate flex items-center text-sm font-medium text-amber-600 hover:text-amber-700 dark:text-amber-500 dark:hover:text-amber-400 ml-auto">
                      <i class="material-icons text-[18px] mr-1">gavel</i>
                      Moderate
                    </button>
                  <% end %>
                </div>
              </div>
              
              <div class="feed-item-status shrink-0 flex items-start sm:items-center pt-1 sm:pt-0">
                <% if post.pending_moderation? %>
                  <span class="status-badge pending inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-amber-100 text-amber-800 dark:bg-amber-900/30 dark:text-amber-400 border border-amber-200 dark:border-amber-800/50">
                    <i class="material-icons text-[12px] mr-1">pending_actions</i> Pending
                  </span>
                <% elsif post.blocked? %>
                  <span class="status-badge blocked inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-red-100 text-red-800 dark:bg-red-900/30 dark:text-red-400 border border-red-200 dark:border-red-800/50">
                    <i class="material-icons text-[12px] mr-1">block</i> Blocked
                  </span>
                <% end %>
              </div>
            </div>
          <% end %>
        </div>
      </div>
      
      <div class="flex justify-center">
        <%= paginate @posts %>
      </div>
    <% else %>
      <div class="thredded--empty bg-white dark:bg-slate-800 rounded-lg shadow-sm border border-slate-200 dark:border-slate-700 py-16 px-6 text-center mt-8">
        <div class="empty-icon text-slate-300 dark:text-slate-600 mb-4 inline-block">
          <i class="material-icons text-[48px]">timeline</i>
        </div>
        <h3 class="thredded--empty--title text-xl font-bold text-slate-800 dark:text-white mb-2">No recent activity</h3>
        <p class="text-slate-500 dark:text-slate-400">There's no forum activity to display at the moment.</p>
      </div>
    <% end %>
  </div>
<% end %>