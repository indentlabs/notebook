<% if thredded_moderator? %>
  <% current = current_page_moderation? %>
  <li class="thredded--user-navigation--item thredded--user-navigation--moderation<%= ' thredded--is-current' if current %> flex items-center h-full m-0">
    <%= link_to current ? nav_back_path : pending_moderation_path,
                rel: 'nofollow',
                class: 'flex items-center h-full px-4 py-3 no-underline text-gray-700 dark:text-gray-200 hover:bg-gray-100 dark:hover:bg-gray-700 transition-colors',
                title: t('thredded.nav.moderation') do %>
      <span class="text-sm"><%= t 'thredded.nav.moderation' %></span>
      <% if posts_pending_moderation_count > 0 %>
        <span class="ml-1 inline-flex items-center px-1.5 py-0.5 rounded-full text-xs font-medium bg-red-100 text-red-800 dark:bg-red-900 dark:text-red-200">
          <%= posts_pending_moderation_count %>
        </span>
      <% end %>
    <% end %>
  </li>
<% end %>