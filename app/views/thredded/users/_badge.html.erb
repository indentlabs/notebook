<%
  badge_classes = 'text-xs ml-2'
  badge_text    = user.forums_badge_text

  if user.favorite_page_type?
    begin
      route_helper_name = "#{user.favorite_page_type.downcase.pluralize}_user_path"
      favorite_link = link_to main_app.send(route_helper_name, id: user.id) do
        content_tag(:i, class: "material-icons align-middle mr-1 #{content_class_from_name(user.favorite_page_type).try(:text_color)}", style: "font-size: 16px;") do
          "#{content_class_from_name(user.favorite_page_type).try(:icon)}"
        end
      end

      badge_text = favorite_link + badge_text
    rescue NoMethodError
      # Route helper not available for this page type, skip favorite link
    end
  end
%>

<% if user.respond_to?(:selected_billing_plan_id) %>
  <% if user.id == 5 %>
    <span class="<%= badge_classes %> px-2 py-0.5 rounded" style="background: #2196F3; color: white">
      <%= badge_text.presence || 'Admin' %>
    </span>
  <% elsif user.selected_billing_plan_id == 2 %>
    <span class="<%= badge_classes %> px-2 py-0.5 rounded" style="background: #dedeff; color: black">
      <%= badge_text.presence || 'Beta Tester' %>
    </span>
  <% elsif user.selected_billing_plan_id == 3 %>
    <span class="<%= badge_classes %> px-2 py-0.5 rounded" style="background: #ffdede; color: black">
      <%= badge_text.presence || 'Early Adopter' %>
    </span>
  <% elsif user.on_premium_plan? %>
    <span class="<%= badge_classes %> px-2 py-0.5 rounded" style="background: #ffffaa; color: black">
      <%= badge_text.presence || 'Premium Supporter' %>
    </span>
  <% else %>
    <%= favorite_link %>
  <% end %>
<% end %>
