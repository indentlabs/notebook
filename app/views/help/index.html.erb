<%# ========== HERO SECTION ========== %>
<section style="height: 30vh; min-height: 200px;">
  <div class="h-full bg-notebook-blue flex shadow-lg">
    <div class="container mx-auto p-4 flex items-center z-10">
      <div class="text-center w-full">
        <div class="text-white tracking-widest py-4 px-5">
          <div class="mb-3 text-4xl md:text-5xl font-bold" style="text-shadow: 0px 2px 4px rgba(0, 0, 0, 0.3);">
            <i class="material-icons text-5xl text-blue-200 align-middle mr-2">help_outline</i>
            How can we help you?
          </div>
          <div class="leading-normal text-xl md:text-2xl text-blue-100" style="text-shadow: 0px 1px 2px rgba(0, 0, 0, 0.2);">
            Guides, tutorials, and resources for worldbuilders and writers
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
  <!-- Main Content -->
  <div class="space-y-12">

    <!-- Feedback and Surveys Section -->
    <section>
      <div class="flex items-center mb-4">
        <i class="material-icons text-green-600 dark:text-green-400 mr-2">feedback</i>
        <h2 class="text-2xl font-semibold text-gray-800 dark:text-white">Feedback and surveys</h2>
      </div>

      <div class="bg-white dark:bg-gray-800 rounded-lg shadow-sm border border-gray-100 dark:border-gray-700 p-6 mb-6">
        <div class="prose text-gray-600 dark:text-gray-300 max-w-none">
          <p>
            The following links will open a new tab to Google Forms. All responses are anonymous and separated from your Notebook.ai account, so please
            provide an email address if you would like a response or follow-up.
          </p>
          <p>
            You can also ask for help from other users on <%= link_to 'the forums', 'https://www.notebook.ai/forum/site-support', class: 'text-blue-600 dark:text-blue-400 hover:text-blue-800 dark:hover:text-blue-300' %>.
          </p>
          <p>
            Thank you for helping make Notebook.ai better!
          </p>
        </div>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-4">
        <!-- General Feedback Forms -->
        <%= link_to 'https://docs.google.com/forms/d/e/1FAIpQLSe0jnqJlcPJDqwogGere5j8-8F1nSGGYkzbsI-XkOeMnGwLrA/viewform', target: '_blank', class: 'block h-full' do %>
          <div class="bg-white dark:bg-gray-800 rounded-lg shadow-sm border border-gray-100 dark:border-gray-700 hover:shadow-md transition-shadow p-4 flex items-center h-full">
            <div class="bg-red-50 dark:bg-red-900 rounded-full p-2 mr-3 flex-shrink-0">
              <i class="material-icons text-red-600 dark:text-red-200">bug_report</i>
            </div>
            <div class="flex-grow">
              <h3 class="font-medium text-gray-800 dark:text-white">Report a problem</h3>
              <p class="text-sm text-gray-500 dark:text-gray-400">Let us know about any issues you encounter</p>
            </div>
            <i class="material-icons text-gray-400 dark:text-gray-500 flex-shrink-0 ml-2">open_in_new</i>
          </div>
        <% end %>

        <%= link_to 'https://docs.google.com/forms/d/e/1FAIpQLScOhSMdDqWqJu9HGPQdmd0R9s90_AcSo0g6_Nc1qNjQIbSaXA/viewform', target: '_blank', class: 'block h-full' do %>
          <div class="bg-white dark:bg-gray-800 rounded-lg shadow-sm border border-gray-100 dark:border-gray-700 hover:shadow-md transition-shadow p-4 flex items-center h-full">
            <div class="bg-blue-50 dark:bg-blue-900 rounded-full p-2 mr-3 flex-shrink-0">
              <i class="material-icons text-blue-600 dark:text-blue-200">lightbulb</i>
            </div>
            <div class="flex-grow">
              <h3 class="font-medium text-gray-800 dark:text-white">Request a feature</h3>
              <p class="text-sm text-gray-500 dark:text-gray-400">Suggest new features or improvements</p>
            </div>
            <i class="material-icons text-gray-400 dark:text-gray-500 flex-shrink-0 ml-2">open_in_new</i>
          </div>
        <% end %>

        <%= link_to 'https://docs.google.com/forms/d/e/1FAIpQLScZWEVMgm8hBWIIVj1LPzo0GqflmWUrLQlc4TAYqsaS087oAA/viewform', target: '_blank', class: 'block h-full' do %>
          <div class="bg-white dark:bg-gray-800 rounded-lg shadow-sm border border-gray-100 dark:border-gray-700 hover:shadow-md transition-shadow p-4 flex items-center h-full">
            <div class="bg-green-50 dark:bg-green-900 rounded-full p-2 mr-3 flex-shrink-0">
              <i class="material-icons text-green-600 dark:text-green-200">rate_review</i>
            </div>
            <div class="flex-grow">
              <h3 class="font-medium text-gray-800 dark:text-white">Leave feedback</h3>
              <p class="text-sm text-gray-500 dark:text-gray-400">Share your thoughts about Notebook.ai</p>
            </div>
            <i class="material-icons text-gray-400 dark:text-gray-500 flex-shrink-0 ml-2">open_in_new</i>
          </div>
        <% end %>

        <%= link_to 'https://docs.google.com/forms/d/e/1FAIpQLSctM_QaTIYTaj4WS546L--9WBbEIxAA9LKhWINb5CzguLR-JQ/viewform?usp=sf_link', target: '_blank', class: 'block h-full' do %>
          <div class="bg-white dark:bg-gray-800 rounded-lg shadow-sm border border-gray-100 dark:border-gray-700 hover:shadow-md transition-shadow p-4 flex items-center h-full">
            <div class="bg-yellow-50 dark:bg-yellow-900 rounded-full p-2 mr-3 flex-shrink-0">
              <i class="material-icons text-yellow-600 dark:text-yellow-200">smartphone</i>
            </div>
            <div class="flex-grow">
              <h3 class="font-medium text-gray-800 dark:text-white">Mobile usage survey</h3>
              <p class="text-sm text-gray-500 dark:text-gray-400">Help us improve the mobile experience</p>
            </div>
            <i class="material-icons text-gray-400 dark:text-gray-500 flex-shrink-0 ml-2">open_in_new</i>
          </div>
        <% end %>

        <%= link_to 'https://docs.google.com/forms/d/1PFOaa97Cu3vrceUvcuFT6nyITaMwR-4wQSarUdVoPSg/viewform', target: '_blank', class: 'block h-full' do %>
          <div class="bg-white dark:bg-gray-800 rounded-lg shadow-sm border border-gray-100 dark:border-gray-700 hover:shadow-md transition-shadow p-4 flex items-center h-full">
            <div class="bg-purple-50 dark:bg-purple-900 rounded-full p-2 mr-3 flex-shrink-0">
              <i class="material-icons text-purple-600 dark:text-purple-200">add_circle</i>
            </div>
            <div class="flex-grow">
              <h3 class="font-medium text-gray-800 dark:text-white">Request another page type</h3>
              <p class="text-sm text-gray-500 dark:text-gray-400">Suggest new worldbuilding categories</p>
            </div>
            <i class="material-icons text-gray-400 dark:text-gray-500 flex-shrink-0 ml-2">open_in_new</i>
          </div>
        <% end %>

        <!-- Premium User Forms -->
        <% if user_signed_in? && current_user.on_premium_plan? %>
          <%= link_to 'https://docs.google.com/forms/d/e/1FAIpQLScjWJfW2p9LoGfKe9uEn4xWvve-AhX3QtY7hqm7BCyyK0HdRA/viewform?usp=sf_link', target: '_blank', class: 'block h-full' do %>
            <div class="bg-white dark:bg-gray-800 rounded-lg shadow-sm border border-gray-100 dark:border-gray-700 hover:shadow-md transition-shadow p-4 flex items-center h-full">
              <div class="bg-indigo-50 dark:bg-indigo-900 rounded-full p-2 mr-3 flex-shrink-0">
                <i class="material-icons text-indigo-600 dark:text-indigo-200">psychology</i>
              </div>
              <div class="flex-grow">
                <h3 class="font-medium text-gray-800 dark:text-white">Document Analysis Feedback</h3>
                <p class="text-sm text-gray-500 dark:text-gray-400">Share your experience with AI analysis</p>
              </div>
              <i class="material-icons text-gray-400 dark:text-gray-500 flex-shrink-0 ml-2">open_in_new</i>
            </div>
          <% end %>

          <%= link_to 'https://docs.google.com/forms/d/e/1FAIpQLSfHHcOpU-CD9EFILPVMd4ZtgWIFkxmzLMW1mdvanJqqLKgMAA/viewform?usp=sf_link', target: '_blank', class: 'block h-full' do %>
            <div class="bg-white dark:bg-gray-800 rounded-lg shadow-sm border border-gray-100 dark:border-gray-700 hover:shadow-md transition-shadow p-4 flex items-center h-full">
              <div class="bg-teal-50 dark:bg-teal-900 rounded-full p-2 mr-3 flex-shrink-0">
                <i class="material-icons text-teal-600 dark:text-teal-200">timeline</i>
              </div>
              <div class="flex-grow">
                <h3 class="font-medium text-gray-800 dark:text-white">Timeline Editor Beta Feedback</h3>
                <p class="text-sm text-gray-500 dark:text-gray-400">Help improve the timeline feature</p>
              </div>
              <i class="material-icons text-gray-400 dark:text-gray-500 flex-shrink-0 ml-2">open_in_new</i>
            </div>
          <% end %>

          <%= link_to 'https://docs.google.com/forms/d/e/1FAIpQLScCPsoJxLxOC_nY3nMrtENja33lnMXNDrZLtWOxS2BYCNlpCQ/viewform?usp=sf_link', target: '_blank', class: 'block h-full' do %>
            <div class="bg-white dark:bg-gray-800 rounded-lg shadow-sm border border-gray-100 dark:border-gray-700 hover:shadow-md transition-shadow p-4 flex items-center h-full">
              <div class="bg-pink-50 dark:bg-pink-900 rounded-full p-2 mr-3 flex-shrink-0">
                <i class="material-icons text-pink-600 dark:text-pink-200">collections_bookmark</i>
              </div>
              <div class="flex-grow">
                <h3 class="font-medium text-gray-800 dark:text-white">Collections feedback</h3>
                <p class="text-sm text-gray-500 dark:text-gray-400">Share thoughts on the collections feature</p>
              </div>
              <i class="material-icons text-gray-400 dark:text-gray-500 flex-shrink-0 ml-2">open_in_new</i>
            </div>
          <% end %>
        <% end %>
      </div>
    </section>

    <!-- Worldbuilding Pages Section -->
    <section>
      <div class="flex items-center mb-4">
        <i class="material-icons text-blue-600 dark:text-blue-400 mr-2">menu_book</i>
        <h2 class="text-2xl font-semibold text-gray-800 dark:text-white">About our worldbuilding pages</h2>
      </div>
      <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6 gap-3">
        <% Rails.application.config.content_types[:all].each do |content_type| %>
          <%= link_to send("#{content_type.name.downcase}_worldbuilding_info_path"), class: "block" do %>
            <div class="bg-white dark:bg-gray-800 rounded-lg shadow-sm border border-gray-100 dark:border-gray-700 hover:shadow-md transition-shadow overflow-hidden">
              <div class="p-4 <%= content_type.color %> text-white flex items-center justify-center">
                <i class="material-icons text-2xl"><%= content_type.icon %></i>
              </div>
              <div class="p-2 text-center text-sm font-medium text-gray-700 dark:text-gray-300">
                <%= content_type.name.pluralize %>
              </div>
            </div>
          <% end %>
        <% end %>
      </div>
    </section>

    <!-- Writing Tools Section -->
    <section>
      <div class="flex items-center mb-4">
        <i class="material-icons text-emerald-600 dark:text-emerald-400 mr-2">edit_note</i>
        <h2 class="text-2xl font-semibold text-gray-800 dark:text-white">Writing Tools</h2>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        <%= link_to timeline_worldbuilding_info_path, class: "block h-full" do %>
          <div class="bg-white dark:bg-gray-800 rounded-lg shadow-sm border border-gray-100 dark:border-gray-700 hover:shadow-md transition-shadow overflow-hidden h-full flex flex-col">
            <div class="p-4 <%= Timeline.color %> text-white flex items-center">
              <i class="material-icons text-2xl mr-3"><%= Timeline.icon %></i>
              <h3 class="font-medium text-lg">Timelines</h3>
            </div>
            <div class="p-4 flex-grow">
              <p class="text-sm text-gray-500 dark:text-gray-400">Track events, plot points, and chronological stories within your fictional world.</p>
            </div>
          </div>
        <% end %>
        <%= link_to document_worldbuilding_info_path, class: "block h-full" do %>
          <div class="bg-white dark:bg-gray-800 rounded-lg shadow-sm border border-gray-100 dark:border-gray-700 hover:shadow-md transition-shadow overflow-hidden h-full flex flex-col">
            <div class="p-4 <%= Document.color %> text-white flex items-center">
              <i class="material-icons text-2xl mr-3"><%= Document.icon %></i>
              <h3 class="font-medium text-lg">Documents</h3>
            </div>
            <div class="p-4 flex-grow">
              <p class="text-sm text-gray-500 dark:text-gray-400">Write chapters and scenes with our integrated editor. Link worldbuilding pages directly in your drafts.</p>
            </div>
          </div>
        <% end %>
        <%= link_to book_worldbuilding_info_path, class: "block h-full" do %>
          <div class="bg-white dark:bg-gray-800 rounded-lg shadow-sm border border-gray-100 dark:border-gray-700 hover:shadow-md transition-shadow overflow-hidden h-full flex flex-col">
            <div class="p-4 <%= Book.color %> text-white flex items-center">
              <i class="material-icons text-2xl mr-3"><%= Book.icon %></i>
              <h3 class="font-medium text-lg">Books</h3>
            </div>
            <div class="p-4 flex-grow">
              <p class="text-sm text-gray-500 dark:text-gray-400">Organize chapters, track word counts, and set writing goals to finish your next novel.</p>
            </div>
          </div>
        <% end %>
      </div>
    </section>

    <!-- Documentation Section -->
    <section>
      <div class="flex items-center mb-4">
        <i class="material-icons text-purple-600 dark:text-purple-400 mr-2">library_books</i>
        <h2 class="text-2xl font-semibold text-gray-800 dark:text-white">Documentation</h2>
      </div>
      
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 mb-12">
        <%= link_to help_your_first_universe_path, class: "block h-full" do %>
          <div class="bg-white dark:bg-gray-800 rounded-lg shadow-sm border border-gray-100 dark:border-gray-700 hover:shadow-md transition-shadow p-6 h-full flex flex-col">
            <div class="flex items-center mb-3">
              <div class="bg-blue-50 dark:bg-blue-900 rounded-full p-2 mr-3">
                <i class="material-icons text-blue-600 dark:text-blue-200">language</i>
              </div>
              <h3 class="font-medium text-gray-800 dark:text-white">Your First Universe</h3>
            </div>
            <p class="text-sm text-gray-500 dark:text-gray-400 mb-4 flex-grow">Step-by-step guide to creating your first fictional universe. Learn how to organize characters, locations, items, and build the foundation of your worldbuilding project.</p>
            <div class="flex items-center text-sm text-blue-600 dark:text-blue-400 font-medium">
              <span>Read guide</span>
              <i class="material-icons ml-1 text-sm">arrow_forward</i>
            </div>
          </div>
        <% end %>
        
        <%= link_to help_page_templates_path, class: "block h-full" do %>
          <div class="bg-white dark:bg-gray-800 rounded-lg shadow-sm border border-gray-100 dark:border-gray-700 hover:shadow-md transition-shadow p-6 h-full flex flex-col">
            <div class="flex items-center mb-3">
              <div class="bg-purple-50 dark:bg-purple-900 rounded-full p-2 mr-3">
                <i class="material-icons text-purple-600 dark:text-purple-200">tune</i>
              </div>
              <h3 class="font-medium text-gray-800 dark:text-white">Page Templates</h3>
            </div>
            <p class="text-sm text-gray-500 dark:text-gray-400 mb-4 flex-grow">Learn how to customize templates to structure your content perfectly. Complete guide to categories, fields, and template management.</p>
            <div class="flex items-center text-sm text-purple-600 dark:text-purple-400 font-medium">
              <span>Read guide</span>
              <i class="material-icons ml-1 text-sm">arrow_forward</i>
            </div>
          </div>
        <% end %>
        
        <%= link_to help_organizing_with_universes_path, class: "block h-full" do %>
          <div class="bg-white dark:bg-gray-800 rounded-lg shadow-sm border border-gray-100 dark:border-gray-700 hover:shadow-md transition-shadow p-6 h-full flex flex-col">
            <div class="flex items-center mb-3">
              <div class="bg-blue-50 dark:bg-blue-900 rounded-full p-2 mr-3">
                <i class="material-icons text-blue-600 dark:text-blue-200">language</i>
              </div>
              <h3 class="font-medium text-gray-800 dark:text-white">Organizing with Universes</h3>
            </div>
            <p class="text-sm text-gray-500 dark:text-gray-400 mb-4 flex-grow">Master the art of worldbuilding organization with universes. Learn about privacy, collaboration, focus mode, and best practices for managing complex fictional worlds.</p>
            <div class="flex items-center text-sm text-blue-600 dark:text-blue-400 font-medium">
              <span>Read guide</span>
              <i class="material-icons ml-1 text-sm">arrow_forward</i>
            </div>
          </div>
        <% end %>
        
        <%= link_to help_page_visualization_path, class: "block h-full" do %>
          <div class="bg-white dark:bg-gray-800 rounded-lg shadow-sm border border-gray-100 dark:border-gray-700 hover:shadow-md transition-shadow p-6 h-full flex flex-col">
            <div class="flex items-center mb-3">
              <div class="bg-purple-50 dark:bg-purple-900 rounded-full p-2 mr-3">
                <i class="material-icons text-purple-600 dark:text-purple-200">visibility</i>
              </div>
              <h3 class="font-medium text-gray-800 dark:text-white">Page Visualization with Basil</h3>
            </div>
            <p class="text-sm text-gray-500 dark:text-gray-400 mb-4 flex-grow">Complete guide to visualizing your worldbuilding content with Basil. Generate character portraits, location art, and item illustrations from your page details.</p>
            <div class="flex items-center text-sm text-purple-600 dark:text-purple-400 font-medium">
              <span>Read guide</span>
              <i class="material-icons ml-1 text-sm">arrow_forward</i>
            </div>
          </div>
        <% end %>
        
        <%= link_to help_document_analysis_path, class: "block h-full" do %>
          <div class="bg-white dark:bg-gray-800 rounded-lg shadow-sm border border-gray-100 dark:border-gray-700 hover:shadow-md transition-shadow p-6 h-full flex flex-col">
            <div class="flex items-center mb-3">
              <div class="bg-indigo-50 dark:bg-indigo-900 rounded-full p-2 mr-3">
                <i class="material-icons text-indigo-600 dark:text-indigo-200">psychology</i>
              </div>
              <h3 class="font-medium text-gray-800 dark:text-white">Document Analysis</h3>
            </div>
            <p class="text-sm text-gray-500 dark:text-gray-400 mb-4 flex-grow">Master AI-powered document analysis to automatically extract characters, locations, and plot elements from your manuscripts and stories.</p>
            <div class="flex items-center text-sm text-indigo-600 dark:text-indigo-400 font-medium">
              <span>Read guide</span>
              <i class="material-icons ml-1 text-sm">arrow_forward</i>
            </div>
          </div>
        <% end %>
        
        <%= link_to help_organizing_with_tags_path, class: "block h-full" do %>
          <div class="bg-white dark:bg-gray-800 rounded-lg shadow-sm border border-gray-100 dark:border-gray-700 hover:shadow-md transition-shadow p-6 h-full flex flex-col">
            <div class="flex items-center mb-3">
              <div class="bg-orange-50 dark:bg-orange-900 rounded-full p-2 mr-3">
                <i class="material-icons text-orange-600 dark:text-orange-200">tag</i>
              </div>
              <h3 class="font-medium text-gray-800 dark:text-white">Organizing with Tags</h3>
            </div>
            <p class="text-sm text-gray-500 dark:text-gray-400 mb-4 flex-grow">Master the art of content organization using tags. Learn how to create, manage, and use tags to efficiently organize and discover your worldbuilding content.</p>
            <div class="flex items-center text-sm text-orange-600 dark:text-orange-400 font-medium">
              <span>Read guide</span>
              <i class="material-icons ml-1 text-sm">arrow_forward</i>
            </div>
          </div>
        <% end %>

        <%= link_to help_your_account_path, class: "block h-full" do %>
          <div class="bg-white dark:bg-gray-800 rounded-lg shadow-sm border border-gray-100 dark:border-gray-700 hover:shadow-md transition-shadow p-6 h-full flex flex-col">
            <div class="flex items-center mb-3">
              <div class="bg-gray-100 dark:bg-gray-700 rounded-full p-2 mr-3">
                <i class="material-icons text-gray-600 dark:text-gray-300">account_circle</i>
              </div>
              <h3 class="font-medium text-gray-800 dark:text-white">Managing Your Account</h3>
            </div>
            <p class="text-sm text-gray-500 dark:text-gray-400 mb-4 flex-grow">Profile settings, password management, email notifications, billing, and account security options.</p>
            <div class="flex items-center text-sm text-gray-600 dark:text-gray-400 font-medium">
              <span>Read guide</span>
              <i class="material-icons ml-1 text-sm">arrow_forward</i>
            </div>
          </div>
        <% end %>

        <%= link_to help_your_data_path, class: "block h-full" do %>
          <div class="bg-white dark:bg-gray-800 rounded-lg shadow-sm border border-gray-100 dark:border-gray-700 hover:shadow-md transition-shadow p-6 h-full flex flex-col">
            <div class="flex items-center mb-3">
              <div class="bg-amber-50 dark:bg-amber-900 rounded-full p-2 mr-3">
                <i class="material-icons text-amber-600 dark:text-amber-200">cloud_download</i>
              </div>
              <h3 class="font-medium text-gray-800 dark:text-white">Your Data</h3>
            </div>
            <p class="text-sm text-gray-500 dark:text-gray-400 mb-4 flex-grow">Data Vault overview, export formats (TXT, MD, JSON, XML, YAML, CSV), recycle bin, archives, and storage limits.</p>
            <div class="flex items-center text-sm text-amber-600 dark:text-amber-400 font-medium">
              <span>Read guide</span>
              <i class="material-icons ml-1 text-sm">arrow_forward</i>
            </div>
          </div>
        <% end %>

        <%= link_to help_troubleshooting_path, class: "block h-full" do %>
          <div class="bg-white dark:bg-gray-800 rounded-lg shadow-sm border border-gray-100 dark:border-gray-700 hover:shadow-md transition-shadow p-6 h-full flex flex-col">
            <div class="flex items-center mb-3">
              <div class="bg-red-50 dark:bg-red-900 rounded-full p-2 mr-3">
                <i class="material-icons text-red-600 dark:text-red-200">help_outline</i>
              </div>
              <h3 class="font-medium text-gray-800 dark:text-white">Troubleshooting & FAQ</h3>
            </div>
            <p class="text-sm text-gray-500 dark:text-gray-400 mb-4 flex-grow">Common questions and solutions for universes, content, collaboration, images, Premium, and technical issues.</p>
            <div class="flex items-center text-sm text-red-600 dark:text-red-400 font-medium">
              <span>Read guide</span>
              <i class="material-icons ml-1 text-sm">arrow_forward</i>
            </div>
          </div>
        <% end %>
      </div>
    </section>

    <!-- Features & Capabilities Section -->
    <section>
      <div class="flex items-center mb-4">
        <i class="material-icons text-green-600 dark:text-green-400 mr-2">info</i>
        <h2 class="text-2xl font-semibold text-gray-800 dark:text-white">Features & Capabilities</h2>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-2 gap-4">
        <%= link_to help_free_features_path, class: "block" do %>
