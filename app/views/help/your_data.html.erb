<% content_for :title, "Your Data - Notebook.ai Help" %>

<!-- Hero Header -->
<div class="bg-gradient-to-r from-amber-500 to-orange-500 dark:from-amber-700 dark:to-orange-700 text-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="flex items-center mb-6">
      <%= link_to main_app.help_center_path, class: "inline-flex items-center text-amber-100 hover:text-white transition-colors duration-200" do %>
        <i class="material-icons mr-2">arrow_back</i>
        Back to Help Center
      <% end %>
    </div>

    <div class="flex items-center mb-4">
      <div class="bg-white bg-opacity-20 rounded-full p-3 mr-4">
        <i class="material-icons text-3xl">cloud_download</i>
      </div>
      <div>
        <h1 class="text-4xl font-bold mb-2">Your Data</h1>
        <p class="text-xl text-amber-100">Export, backup, recovery, and storage management</p>
      </div>
    </div>
  </div>
</div>

<!-- Main Content -->
<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
  <div class="flex flex-col lg:flex-row gap-8">

    <!-- Sticky Table of Contents -->
    <div class="lg:w-1/4">
      <div class="sticky top-8">
        <div class="bg-white dark:bg-gray-800 rounded-lg shadow-md border border-gray-200 dark:border-gray-700 p-6">
          <h3 class="font-semibold text-gray-900 dark:text-white mb-4">Table of Contents</h3>
          <nav class="space-y-2">
            <a href="#data-vault" class="block text-sm text-gray-600 dark:text-gray-300 hover:text-amber-600 dark:hover:text-amber-400 transition-colors duration-200">Data Vault Overview</a>
            <a href="#export" class="block text-sm text-gray-600 dark:text-gray-300 hover:text-amber-600 dark:hover:text-amber-400 transition-colors duration-200">Exporting Your Data</a>
            <a href="#recycle-bin" class="block text-sm text-gray-600 dark:text-gray-300 hover:text-amber-600 dark:hover:text-amber-400 transition-colors duration-200">Recycle Bin</a>
            <a href="#archives" class="block text-sm text-gray-600 dark:text-gray-300 hover:text-amber-600 dark:hover:text-amber-400 transition-colors duration-200">Archives</a>
            <a href="#storage" class="block text-sm text-gray-600 dark:text-gray-300 hover:text-amber-600 dark:hover:text-amber-400 transition-colors duration-200">Storage Limits</a>
            <a href="#uploads" class="block text-sm text-gray-600 dark:text-gray-300 hover:text-amber-600 dark:hover:text-amber-400 transition-colors duration-200">Managing Uploads</a>
          </nav>
        </div>
      </div>
    </div>

    <!-- Main Content -->
    <div class="lg:w-3/4">
      <div class="prose prose-lg max-w-none">

        <!-- Data Vault -->
        <section id="data-vault" class="mb-12">
          <div class="bg-amber-50 dark:bg-gray-700 border-l-4 border-amber-400 dark:border-amber-500 p-6 rounded-r-lg mb-6">
            <h2 class="text-2xl font-bold text-amber-900 dark:text-amber-100 mb-4 flex items-center">
              <i class="material-icons mr-3 text-amber-600 dark:text-amber-400">dashboard</i>
              Data Vault Overview
            </h2>
            <p class="text-amber-800 dark:text-amber-200 leading-relaxed">
              The Data Vault is your central hub for managing all your Notebook.ai data, analytics, and account tools.
            </p>
          </div>

          <p class="text-gray-700 dark:text-gray-300 mb-4">
            Access the Data Vault from the sidebar or navigation menu. It provides quick access to:
          </p>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-6">
            <div class="bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg p-4">
              <h4 class="font-semibold text-gray-900 dark:text-white mb-2 flex items-center">
                <i class="material-icons text-blue-600 dark:text-blue-400 mr-2 text-sm">insert_chart</i>
                Usage Analytics
              </h4>
              <p class="text-sm text-gray-600 dark:text-gray-400">View statistics about your worldbuilding activity.</p>
            </div>
            <div class="bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg p-4">
              <h4 class="font-semibold text-gray-900 dark:text-white mb-2 flex items-center">
                <i class="material-icons text-purple-600 dark:text-purple-400 mr-2 text-sm">date_range</i>
                Year in Review
              </h4>
              <p class="text-sm text-gray-600 dark:text-gray-400">Explore your yearly activity and achievements.</p>
            </div>
            <div class="bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg p-4">
              <h4 class="font-semibold text-gray-900 dark:text-white mb-2 flex items-center">
                <i class="material-icons text-green-600 dark:text-green-400 mr-2 text-sm">public</i>
                Eco Footprint
              </h4>
              <p class="text-sm text-gray-600 dark:text-gray-400">See your environmental impact from going digital.</p>
            </div>
            <div class="bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg p-4">
              <h4 class="font-semibold text-gray-900 dark:text-white mb-2 flex items-center">
                <i class="material-icons text-amber-600 dark:text-amber-400 mr-2 text-sm">emoji_events</i>
                Achievements
              </h4>
              <p class="text-sm text-gray-600 dark:text-gray-400">Track your worldbuilding milestones.</p>
            </div>
          </div>

          <div class="bg-blue-50 dark:bg-gray-700 border border-blue-200 dark:border-blue-700 rounded-lg p-4 mb-6">
            <h4 class="font-semibold text-blue-900 dark:text-blue-100 mb-2 flex items-center">
              <i class="material-icons mr-2 text-blue-600 dark:text-blue-400">link</i>
              Quick Link
            </h4>
            <p class="text-blue-800 dark:text-blue-200 text-sm">
              Go directly to your <%= link_to 'Data Vault', data_vault_path, class: 'text-blue-600 dark:text-blue-400 hover:underline font-medium' %>.
            </p>
          </div>
        </section>

        <!-- Export -->
        <section id="export" class="mb-12">
          <div class="bg-green-50 dark:bg-gray-700 border-l-4 border-green-400 dark:border-green-500 p-6 rounded-r-lg mb-6">
            <h2 class="text-2xl font-bold text-green-900 dark:text-green-100 mb-4 flex items-center">
              <i class="material-icons mr-3 text-green-600 dark:text-green-400">file_download</i>
              Exporting Your Data
            </h2>
          </div>

          <p class="text-gray-700 dark:text-gray-300 mb-4">
            Notebook.ai supports multiple export formats so you can backup your data or use it in other applications.
          </p>

          <h3 class="text-xl font-semibold text-gray-900 dark:text-white mb-4">Available Formats</h3>

          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4 mb-6">
            <div class="bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg p-4">
              <div class="flex items-center mb-2">
                <span class="bg-blue-100 dark:bg-blue-900 text-blue-800 dark:text-blue-200 text-xs px-2 py-1 rounded mr-2">TXT</span>
                <h4 class="font-semibold text-gray-900 dark:text-white">Text Outline</h4>
              </div>
              <p class="text-sm text-gray-600 dark:text-gray-400">Human-readable text format, great for quick review.</p>
            </div>
            <div class="bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg p-4">
              <div class="flex items-center mb-2">
                <span class="bg-blue-100 dark:bg-blue-900 text-blue-800 dark:text-blue-200 text-xs px-2 py-1 rounded mr-2">MD</span>
                <h4 class="font-semibold text-gray-900 dark:text-white">Markdown</h4>
              </div>
              <p class="text-sm text-gray-600 dark:text-gray-400">Formatted text that converts easily to HTML.</p>
            </div>
            <div class="bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg p-4">
              <div class="flex items-center mb-2">
                <span class="bg-green-100 dark:bg-green-900 text-green-800 dark:text-green-200 text-xs px-2 py-1 rounded mr-2">JSON</span>
                <h4 class="font-semibold text-gray-900 dark:text-white">JSON</h4>
              </div>
              <p class="text-sm text-gray-600 dark:text-gray-400">Structured data format for developers.</p>
            </div>
            <div class="bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg p-4">
              <div class="flex items-center mb-2">
                <span class="bg-green-100 dark:bg-green-900 text-green-800 dark:text-green-200 text-xs px-2 py-1 rounded mr-2">XML</span>
                <h4 class="font-semibold text-gray-900 dark:text-white">XML</h4>
              </div>
              <p class="text-sm text-gray-600 dark:text-gray-400">Universal data exchange format.</p>
            </div>
            <div class="bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg p-4">
              <div class="flex items-center mb-2">
                <span class="bg-green-100 dark:bg-green-900 text-green-800 dark:text-green-200 text-xs px-2 py-1 rounded mr-2">YAML</span>
                <h4 class="font-semibold text-gray-900 dark:text-white">YAML</h4>
              </div>
              <p class="text-sm text-gray-600 dark:text-gray-400">Human-readable structured format.</p>
            </div>
            <div class="bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg p-4">
              <div class="flex items-center mb-2">
                <span class="bg-yellow-100 dark:bg-yellow-900 text-yellow-800 dark:text-yellow-200 text-xs px-2 py-1 rounded mr-2">CSV</span>
                <h4 class="font-semibold text-gray-900 dark:text-white">Spreadsheet</h4>
              </div>
              <p class="text-sm text-gray-600 dark:text-gray-400">Import into Excel or Google Sheets.</p>
            </div>
          </div>

          <div class="bg-blue-50 dark:bg-gray-700 border border-blue-200 dark:border-blue-700 rounded-lg p-4 mb-6">
            <h4 class="font-semibold text-blue-900 dark:text-blue-100 mb-2 flex items-center">
              <i class="material-icons mr-2 text-blue-600 dark:text-blue-400">link</i>
              Quick Link
            </h4>
            <p class="text-blue-800 dark:text-blue-200 text-sm">
              Go directly to <%= link_to 'Export Your Data', notebook_export_path, class: 'text-blue-600 dark:text-blue-400 hover:underline font-medium' %>.
            </p>
          </div>
        </section>

        <!-- Recycle Bin -->
        <section id="recycle-bin" class="mb-12">
          <div class="bg-red-50 dark:bg-gray-700 border-l-4 border-red-400 dark:border-red-500 p-6 rounded-r-lg mb-6">
            <h2 class="text-2xl font-bold text-red-900 dark:text-red-100 mb-4 flex items-center">
              <i class="material-icons mr-3 text-red-600 dark:text-red-400">delete</i>
              Recycle Bin
            </h2>
          </div>

          <p class="text-gray-700 dark:text-gray-300 mb-4">
            When you delete content, it goes to the Recycle Bin where you can recover it if needed.
          </p>

          <h3 class="text-xl font-semibold text-gray-900 dark:text-white mb-4">Recovering Deleted Content</h3>
          <ol class="list-decimal list-inside space-y-2 text-gray-700 dark:text-gray-300 mb-6 ml-4">
            <li>Go to your <%= link_to 'Recycle Bin', recently_deleted_content_path, class: 'text-blue-600 dark:text-blue-400 hover:underline' %></li>
            <li>Find the content you want to recover</li>
            <li>Click <strong>Restore</strong> to recover it</li>
          </ol>

          <div class="bg-yellow-50 dark:bg-gray-700 border border-yellow-200 dark:border-yellow-700 rounded-lg p-4 mb-6">
            <h4 class="font-semibold text-yellow-900 dark:text-yellow-100 mb-2 flex items-center">
              <i class="material-icons mr-2 text-yellow-600 dark:text-yellow-400">warning</i>
              Important
            </h4>
            <p class="text-yellow-800 dark:text-yellow-200 text-sm">
              Content in the Recycle Bin is automatically permanently deleted after 30 days. Recover important content before then.
            </p>
          </div>
        </section>

        <!-- Archives -->
        <section id="archives" class="mb-12">
          <div class="bg-gray-100 dark:bg-gray-700 border-l-4 border-gray-400 dark:border-gray-500 p-6 rounded-r-lg mb-6">
            <h2 class="text-2xl font-bold text-gray-900 dark:text-white mb-4 flex items-center">
              <i class="material-icons mr-3 text-gray-600 dark:text-gray-400">archive</i>
              Archives
            </h2>
          </div>

          <p class="text-gray-700 dark:text-gray-300 mb-4">
            Archives let you hide content you're no longer actively working on without deleting it. Archived content:
          </p>

          <ul class="list-disc list-inside space-y-1 text-gray-700 dark:text-gray-300 mb-6 ml-4">
            <li>Doesn't appear in your main content lists</li>
            <li>Can be restored at any time</li>
            <li>Still counts toward your content totals</li>
            <li>Remains searchable when you need it</li>
          </ul>

          <div class="bg-blue-50 dark:bg-gray-700 border border-blue-200 dark:border-blue-700 rounded-lg p-4 mb-6">
            <h4 class="font-semibold text-blue-900 dark:text-blue-100 mb-2 flex items-center">
              <i class="material-icons mr-2 text-blue-600 dark:text-blue-400">link</i>
              Quick Link
            </h4>
            <p class="text-blue-800 dark:text-blue-200 text-sm">
              Go directly to your <%= link_to 'Archives', archive_path, class: 'text-blue-600 dark:text-blue-400 hover:underline font-medium' %>.
            </p>
          </div>
        </section>

        <!-- Storage -->
        <section id="storage" class="mb-12">
          <div class="bg-purple-50 dark:bg-gray-700 border-l-4 border-purple-400 dark:border-purple-500 p-6 rounded-r-lg mb-6">
            <h2 class="text-2xl font-bold text-purple-900 dark:text-purple-100 mb-4 flex items-center">
              <i class="material-icons mr-3 text-purple-600 dark:text-purple-400">storage</i>
              Storage Limits
            </h2>
          </div>

          <p class="text-gray-700 dark:text-gray-300 mb-4">
            Storage limits apply to uploaded images and files, not to your text content. You can create unlimited pages regardless of your plan.
          </p>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
            <div class="bg-white dark:bg-gray-800 border-2 border-gray-200 dark:border-gray-700 rounded-lg p-6">
              <h4 class="font-semibold text-gray-900 dark:text-white mb-2 flex items-center">
                <i class="material-icons text-green-600 dark:text-green-400 mr-2">explore</i>
                Free Account
              </h4>
              <p class="text-3xl font-bold text-gray-900 dark:text-white mb-2">50 MB</p>
              <p class="text-sm text-gray-600 dark:text-gray-400">For images and uploaded files</p>
            </div>
            <div class="bg-gradient-to-br from-purple-50 to-blue-50 dark:from-purple-900 dark:to-blue-900 border-2 border-purple-200 dark:border-purple-700 rounded-lg p-6">
              <h4 class="font-semibold text-purple-900 dark:text-purple-100 mb-2 flex items-center">
                <i class="material-icons text-purple-600 dark:text-purple-400 mr-2">star</i>
                Premium Account
              </h4>
              <p class="text-3xl font-bold text-purple-900 dark:text-purple-100 mb-2">10 GB</p>
              <p class="text-sm text-purple-700 dark:text-purple-300">200x more storage space</p>
            </div>
          </div>

          <p class="text-gray-700 dark:text-gray-300 mb-4">
            Check your current storage usage in your <%= link_to 'Usage Overview', usage_path, class: 'text-blue-600 dark:text-blue-400 hover:underline' %>.
          </p>
        </section>

        <!-- Uploads -->
        <section id="uploads" class="mb-12">
          <div class="bg-yellow-50 dark:bg-gray-700 border-l-4 border-yellow-400 dark:border-yellow-500 p-6 rounded-r-lg mb-6">
            <h2 class="text-2xl font-bold text-yellow-900 dark:text-yellow-100 mb-4 flex items-center">
              <i class="material-icons mr-3 text-yellow-600 dark:text-yellow-400">file_upload</i>
              Managing Uploads
            </h2>
          </div>

          <p class="text-gray-700 dark:text-gray-300 mb-4">
            The Image Uploads section lets you view and manage all images you've uploaded across your pages.
          </p>

          <ul class="list-disc list-inside space-y-1 text-gray-700 dark:text-gray-300 mb-6 ml-4">
            <li>View all your uploaded images in one place</li>
            <li>See which pages use each image</li>
            <li>Delete unused images to free up storage</li>
            <li>Identify large files taking up space</li>
          </ul>

          <div class="bg-blue-50 dark:bg-gray-700 border border-blue-200 dark:border-blue-700 rounded-lg p-4 mb-6">
            <h4 class="font-semibold text-blue-900 dark:text-blue-100 mb-2 flex items-center">
              <i class="material-icons mr-2 text-blue-600 dark:text-blue-400">link</i>
              Quick Link
            </h4>
            <p class="text-blue-800 dark:text-blue-200 text-sm">
              Go directly to <%= link_to 'Image Uploads', uploads_path, class: 'text-blue-600 dark:text-blue-400 hover:underline font-medium' %>.
            </p>
          </div>

          <div class="bg-blue-50 dark:bg-gray-700 border border-blue-200 dark:border-blue-700 rounded-lg p-6">
            <h3 class="font-semibold text-blue-900 dark:text-blue-100 mb-3 flex items-center">
              <i class="material-icons mr-2 text-blue-600 dark:text-blue-400">support</i>
              Need More Space?
            </h3>
            <p class="text-blue-800 dark:text-blue-200 mb-4">
              Premium accounts include 10GB of storage. <%= link_to 'Learn about Premium', help_premium_features_path, class: 'text-blue-600 dark:text-blue-400 hover:underline' %>.
            </p>
          </div>
        </section>

      </div>
    </div>
  </div>
</div>
