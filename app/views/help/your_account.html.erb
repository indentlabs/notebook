<% content_for :title, "Managing Your Account - Notebook.ai Help" %>

<!-- Hero Header -->
<div class="bg-gradient-to-r from-gray-600 to-gray-700 dark:from-gray-800 dark:to-gray-900 text-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="flex items-center mb-6">
      <%= link_to main_app.help_center_path, class: "inline-flex items-center text-gray-300 hover:text-white transition-colors duration-200" do %>
        <i class="material-icons mr-2">arrow_back</i>
        Back to Help Center
      <% end %>
    </div>

    <div class="flex items-center mb-4">
      <div class="bg-white bg-opacity-20 rounded-full p-3 mr-4">
        <i class="material-icons text-3xl">account_circle</i>
      </div>
      <div>
        <h1 class="text-4xl font-bold mb-2">Managing Your Account</h1>
        <p class="text-xl text-gray-200">Profile settings, security, and preferences</p>
      </div>
    </div>
  </div>
</div>

<!-- Main Content -->
<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
  <div class="flex flex-col lg:flex-row gap-8">

    <!-- Sticky Table of Contents -->
    <div class="lg:w-1/4">
      <div class="sticky top-8">
        <div class="bg-white dark:bg-gray-800 rounded-lg shadow-md border border-gray-200 dark:border-gray-700 p-6">
          <h3 class="font-semibold text-gray-900 dark:text-white mb-4">Table of Contents</h3>
          <nav class="space-y-2">
            <a href="#account-settings" class="block text-sm text-gray-600 dark:text-gray-300 hover:text-gray-900 dark:hover:text-white transition-colors duration-200">Account Settings</a>
            <a href="#profile" class="block text-sm text-gray-600 dark:text-gray-300 hover:text-gray-900 dark:hover:text-white transition-colors duration-200">Your Profile</a>
            <a href="#security" class="block text-sm text-gray-600 dark:text-gray-300 hover:text-gray-900 dark:hover:text-white transition-colors duration-200">Password & Security</a>
            <a href="#notifications" class="block text-sm text-gray-600 dark:text-gray-300 hover:text-gray-900 dark:hover:text-white transition-colors duration-200">Email Notifications</a>
            <a href="#billing" class="block text-sm text-gray-600 dark:text-gray-300 hover:text-gray-900 dark:hover:text-white transition-colors duration-200">Billing & Subscription</a>
            <a href="#delete-account" class="block text-sm text-gray-600 dark:text-gray-300 hover:text-gray-900 dark:hover:text-white transition-colors duration-200">Deleting Your Account</a>
          </nav>
        </div>
      </div>
    </div>

    <!-- Main Content -->
    <div class="lg:w-3/4">
      <div class="prose prose-lg max-w-none">

        <!-- Account Settings -->
        <section id="account-settings" class="mb-12">
          <div class="bg-gray-50 dark:bg-gray-700 border-l-4 border-gray-400 dark:border-gray-500 p-6 rounded-r-lg mb-6">
            <h2 class="text-2xl font-bold text-gray-900 dark:text-white mb-4 flex items-center">
              <i class="material-icons mr-3 text-gray-600 dark:text-gray-400">settings</i>
              Account Settings
            </h2>
            <p class="text-gray-700 dark:text-gray-300 leading-relaxed">
              Your account settings control your profile information, login credentials, and notification preferences.
            </p>
          </div>

          <p class="text-gray-700 dark:text-gray-300 mb-4">
            To access your account settings:
          </p>
          <ol class="list-decimal list-inside space-y-2 text-gray-700 dark:text-gray-300 mb-6 ml-4">
            <li>Click on your avatar or username in the navigation bar</li>
            <li>Select <strong>Account Settings</strong> from the dropdown menu</li>
            <li>Or visit your <%= link_to 'Data Vault', data_vault_path, class: 'text-blue-600 dark:text-blue-400 hover:underline' %> and click <strong>Account Settings</strong></li>
          </ol>

          <div class="bg-blue-50 dark:bg-gray-700 border border-blue-200 dark:border-blue-700 rounded-lg p-4 mb-6">
            <h4 class="font-semibold text-blue-900 dark:text-blue-100 mb-2 flex items-center">
              <i class="material-icons mr-2 text-blue-600 dark:text-blue-400">link</i>
              Quick Link
            </h4>
            <p class="text-blue-800 dark:text-blue-200 text-sm">
              Go directly to your <%= link_to 'Account Settings', edit_user_registration_path, class: 'text-blue-600 dark:text-blue-400 hover:underline font-medium' %>.
            </p>
          </div>
        </section>

        <!-- Profile -->
        <section id="profile" class="mb-12">
          <div class="bg-purple-50 dark:bg-gray-700 border-l-4 border-purple-400 dark:border-purple-500 p-6 rounded-r-lg mb-6">
            <h2 class="text-2xl font-bold text-purple-900 dark:text-purple-100 mb-4 flex items-center">
              <i class="material-icons mr-3 text-purple-600 dark:text-purple-400">person</i>
              Your Profile
            </h2>
          </div>

          <p class="text-gray-700 dark:text-gray-300 mb-4">
            Your profile is what other users see when they visit your page or view your public content. You can customize:
          </p>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-6">
            <div class="bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg p-4">
              <h4 class="font-semibold text-gray-900 dark:text-white mb-2">Display Name</h4>
              <p class="text-sm text-gray-600 dark:text-gray-400">The name shown on your profile and in the community.</p>
            </div>
            <div class="bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg p-4">
              <h4 class="font-semibold text-gray-900 dark:text-white mb-2">Avatar</h4>
              <p class="text-sm text-gray-600 dark:text-gray-400">Upload a custom profile picture or use a Gravatar.</p>
            </div>
            <div class="bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg p-4">
              <h4 class="font-semibold text-gray-900 dark:text-white mb-2">Bio</h4>
              <p class="text-sm text-gray-600 dark:text-gray-400">A short description about yourself and your worldbuilding.</p>
            </div>
            <div class="bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg p-4">
              <h4 class="font-semibold text-gray-900 dark:text-white mb-2">Profile Visibility</h4>
              <p class="text-sm text-gray-600 dark:text-gray-400">Control whether your profile is public or private.</p>
            </div>
          </div>
        </section>

        <!-- Security -->
        <section id="security" class="mb-12">
          <div class="bg-green-50 dark:bg-gray-700 border-l-4 border-green-400 dark:border-green-500 p-6 rounded-r-lg mb-6">
            <h2 class="text-2xl font-bold text-green-900 dark:text-green-100 mb-4 flex items-center">
              <i class="material-icons mr-3 text-green-600 dark:text-green-400">security</i>
              Password & Security
            </h2>
          </div>

          <h3 class="text-xl font-semibold text-gray-900 dark:text-white mb-4">Changing Your Password</h3>
          <p class="text-gray-700 dark:text-gray-300 mb-4">
            To change your password:
          </p>
          <ol class="list-decimal list-inside space-y-2 text-gray-700 dark:text-gray-300 mb-6 ml-4">
            <li>Go to your <%= link_to 'Account Settings', edit_user_registration_path, class: 'text-blue-600 dark:text-blue-400 hover:underline' %></li>
            <li>Enter your current password</li>
            <li>Enter your new password twice to confirm</li>
            <li>Click <strong>Update</strong> to save changes</li>
          </ol>

          <div class="bg-yellow-50 dark:bg-gray-700 border border-yellow-200 dark:border-yellow-700 rounded-lg p-4 mb-6">
            <h4 class="font-semibold text-yellow-900 dark:text-yellow-100 mb-2 flex items-center">
              <i class="material-icons mr-2 text-yellow-600 dark:text-yellow-400">lightbulb</i>
              Security Tips
            </h4>
            <ul class="text-yellow-800 dark:text-yellow-200 text-sm space-y-1">
              <li>Use a unique password that you don't use on other sites</li>
              <li>Consider using a password manager</li>
              <li>Choose a password with at least 8 characters</li>
            </ul>
          </div>

          <h3 class="text-xl font-semibold text-gray-900 dark:text-white mb-4">Forgot Your Password?</h3>
          <p class="text-gray-700 dark:text-gray-300 mb-4">
            If you've forgotten your password, you can reset it from the login page by clicking <strong>Forgot your password?</strong>. We'll send a password reset link to your email address.
          </p>
        </section>

        <!-- Notifications -->
        <section id="notifications" class="mb-12">
          <div class="bg-blue-50 dark:bg-gray-700 border-l-4 border-blue-400 dark:border-blue-500 p-6 rounded-r-lg mb-6">
            <h2 class="text-2xl font-bold text-blue-900 dark:text-blue-100 mb-4 flex items-center">
              <i class="material-icons mr-3 text-blue-600 dark:text-blue-400">notifications</i>
              Email Notifications
            </h2>
          </div>

          <p class="text-gray-700 dark:text-gray-300 mb-4">
            Notebook.ai may send you emails for important account activity and updates. You can manage your email preferences in your account settings.
          </p>

          <p class="text-gray-700 dark:text-gray-300 mb-4">
            Types of emails you may receive:
          </p>
          <ul class="list-disc list-inside space-y-1 text-gray-700 dark:text-gray-300 mb-6 ml-4">
            <li>Collaboration invitations</li>
            <li>Important account notices</li>
            <li>Premium subscription updates</li>
            <li>Occasional product updates (opt-out available)</li>
          </ul>

          <p class="text-gray-700 dark:text-gray-300 mb-4">
            Every marketing email includes an unsubscribe link at the bottom.
          </p>
        </section>

        <!-- Billing -->
        <section id="billing" class="mb-12">
          <div class="bg-amber-50 dark:bg-gray-700 border-l-4 border-amber-400 dark:border-amber-500 p-6 rounded-r-lg mb-6">
            <h2 class="text-2xl font-bold text-amber-900 dark:text-amber-100 mb-4 flex items-center">
              <i class="material-icons mr-3 text-amber-600 dark:text-amber-400">payment</i>
              Billing & Subscription
            </h2>
          </div>

          <p class="text-gray-700 dark:text-gray-300 mb-4">
            Manage your Premium subscription, view billing history, and update payment methods from your billing page.
          </p>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-6">
            <%= link_to subscription_path, class: "block" do %>
              <div class="bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg p-4 hover:shadow-md transition-shadow">
                <div class="flex items-center">
                  <i class="material-icons text-amber-600 dark:text-amber-400 mr-3">credit_card</i>
                  <div>
                    <h4 class="font-semibold text-gray-900 dark:text-white">Billing Page</h4>
                    <p class="text-sm text-gray-600 dark:text-gray-400">Manage subscription and payments</p>
                  </div>
                </div>
              </div>
            <% end %>
            <%= link_to billing_history_path, class: "block" do %>
              <div class="bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg p-4 hover:shadow-md transition-shadow">
                <div class="flex items-center">
                  <i class="material-icons text-amber-600 dark:text-amber-400 mr-3">receipt</i>
                  <div>
                    <h4 class="font-semibold text-gray-900 dark:text-white">Billing History</h4>
                    <p class="text-sm text-gray-600 dark:text-gray-400">View past payments and invoices</p>
                  </div>
                </div>
              </div>
            <% end %>
          </div>

          <p class="text-gray-700 dark:text-gray-300 mb-4">
            For detailed billing information, see our <%= link_to 'Billing FAQ', billing_faq_path, class: 'text-blue-600 dark:text-blue-400 hover:underline' %>.
          </p>
        </section>

        <!-- Delete Account -->
        <section id="delete-account" class="mb-12">
          <div class="bg-red-50 dark:bg-gray-700 border-l-4 border-red-400 dark:border-red-500 p-6 rounded-r-lg mb-6">
            <h2 class="text-2xl font-bold text-red-900 dark:text-red-100 mb-4 flex items-center">
              <i class="material-icons mr-3 text-red-600 dark:text-red-400">delete_forever</i>
              Deleting Your Account
            </h2>
          </div>

          <p class="text-gray-700 dark:text-gray-300 mb-4">
            If you wish to delete your Notebook.ai account, please contact us at <strong>andrew@indentlabs.com</strong>. We'll process your request and confirm deletion.
          </p>

          <div class="bg-yellow-50 dark:bg-gray-700 border border-yellow-200 dark:border-yellow-700 rounded-lg p-4 mb-6">
            <h4 class="font-semibold text-yellow-900 dark:text-yellow-100 mb-2 flex items-center">
              <i class="material-icons mr-2 text-yellow-600 dark:text-yellow-400">warning</i>
              Before You Delete
            </h4>
            <p class="text-yellow-800 dark:text-yellow-200 text-sm mb-2">
              Account deletion is permanent. Before deleting, you may want to:
            </p>
            <ul class="text-yellow-800 dark:text-yellow-200 text-sm space-y-1 ml-4">
              <li>Export your data using the <%= link_to 'Export feature', notebook_export_path, class: 'text-yellow-700 dark:text-yellow-300 hover:underline' %></li>
              <li>Cancel any active Premium subscription</li>
              <li>Download any images you've uploaded</li>
            </ul>
          </div>

          <div class="bg-blue-50 dark:bg-gray-700 border border-blue-200 dark:border-blue-700 rounded-lg p-6">
            <h3 class="font-semibold text-blue-900 dark:text-blue-100 mb-3 flex items-center">
              <i class="material-icons mr-2 text-blue-600 dark:text-blue-400">support</i>
              Need Help?
            </h3>
            <p class="text-blue-800 dark:text-blue-200 mb-4">
              If you have questions about your account, our support team is here to help.
            </p>
            <a href="mailto:andrew@indentlabs.com" class="inline-flex items-center px-4 py-2 bg-blue-600 dark:bg-blue-500 text-white rounded-lg hover:bg-blue-700 dark:hover:bg-blue-600 transition-colors duration-200">
              <i class="material-icons mr-2">email</i>
              Contact Support
            </a>
          </div>
        </section>

      </div>
    </div>
  </div>
</div>
