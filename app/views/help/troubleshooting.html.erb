<% content_for :title, "Troubleshooting & FAQ - Notebook.ai Help" %>

<!-- Hero Header -->
<div class="bg-gradient-to-r from-red-500 to-pink-500 dark:from-red-700 dark:to-pink-700 text-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="flex items-center mb-6">
      <%= link_to main_app.help_center_path, class: "inline-flex items-center text-red-100 hover:text-white transition-colors duration-200" do %>
        <i class="material-icons mr-2">arrow_back</i>
        Back to Help Center
      <% end %>
    </div>

    <div class="flex items-center mb-4">
      <div class="bg-white bg-opacity-20 rounded-full p-3 mr-4">
        <i class="material-icons text-3xl">help_outline</i>
      </div>
      <div>
        <h1 class="text-4xl font-bold mb-2">Troubleshooting & FAQ</h1>
        <p class="text-xl text-red-100">Common questions and solutions</p>
      </div>
    </div>
  </div>
</div>

<!-- Main Content -->
<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
  <div class="flex flex-col lg:flex-row gap-8">

    <!-- Sticky Table of Contents -->
    <div class="lg:w-1/4">
      <div class="sticky top-8">
        <div class="bg-white dark:bg-gray-800 rounded-lg shadow-md border border-gray-200 dark:border-gray-700 p-6">
          <h3 class="font-semibold text-gray-900 dark:text-white mb-4">Categories</h3>
          <nav class="space-y-2">
            <a href="#universes" class="block text-sm text-gray-600 dark:text-gray-300 hover:text-red-600 dark:hover:text-red-400 transition-colors duration-200">Universes</a>
            <a href="#content" class="block text-sm text-gray-600 dark:text-gray-300 hover:text-red-600 dark:hover:text-red-400 transition-colors duration-200">Content & Pages</a>
            <a href="#collaboration" class="block text-sm text-gray-600 dark:text-gray-300 hover:text-red-600 dark:hover:text-red-400 transition-colors duration-200">Collaboration</a>
            <a href="#images" class="block text-sm text-gray-600 dark:text-gray-300 hover:text-red-600 dark:hover:text-red-400 transition-colors duration-200">Images & Storage</a>
            <a href="#premium" class="block text-sm text-gray-600 dark:text-gray-300 hover:text-red-600 dark:hover:text-red-400 transition-colors duration-200">Premium & Billing</a>
            <a href="#browser" class="block text-sm text-gray-600 dark:text-gray-300 hover:text-red-600 dark:hover:text-red-400 transition-colors duration-200">Browser & Technical</a>
            <a href="#contact" class="block text-sm text-gray-600 dark:text-gray-300 hover:text-red-600 dark:hover:text-red-400 transition-colors duration-200">Contact Support</a>
          </nav>
        </div>
      </div>
    </div>

    <!-- Main Content -->
    <div class="lg:w-3/4">
      <div class="prose prose-lg max-w-none">

        <!-- Universes -->
        <section id="universes" class="mb-12">
          <div class="bg-purple-50 dark:bg-gray-700 border-l-4 border-purple-400 dark:border-purple-500 p-6 rounded-r-lg mb-6">
            <h2 class="text-2xl font-bold text-purple-900 dark:text-purple-100 mb-2 flex items-center">
              <i class="material-icons mr-3 text-purple-600 dark:text-purple-400">language</i>
              Universes
            </h2>
          </div>

          <div class="space-y-4">
            <div class="bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg p-5">
              <h4 class="font-semibold text-gray-900 dark:text-white mb-2">I can't create more universes</h4>
              <p class="text-gray-700 dark:text-gray-300 text-sm mb-2">
                Free accounts are limited to 5 universes. If you've reached this limit:
              </p>
              <ul class="text-gray-600 dark:text-gray-400 text-sm space-y-1 ml-4 list-disc list-inside">
                <li>Consider consolidating related projects into one universe</li>
                <li>Delete universes you no longer need</li>
                <li><%= link_to 'Upgrade to Premium', subscription_path, class: 'text-blue-600 dark:text-blue-400 hover:underline' %> for unlimited universes</li>
              </ul>
            </div>

            <div class="bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg p-5">
              <h4 class="font-semibold text-gray-900 dark:text-white mb-2">My content isn't showing up in universe focus mode</h4>
              <p class="text-gray-700 dark:text-gray-300 text-sm">
                Make sure the content is assigned to the universe you're focused on. Check the "Universe" field on each page to ensure it's set correctly. Content without a universe won't appear when you're in focus mode.
              </p>
            </div>

            <div class="bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg p-5">
              <h4 class="font-semibold text-gray-900 dark:text-white mb-2">My public universe isn't showing on my profile</h4>
              <p class="text-gray-700 dark:text-gray-300 text-sm">
                Ensure the universe's privacy is set to "public" and that your universe has content in it. Empty universes may not appear in public listings.
              </p>
            </div>
          </div>
        </section>

        <!-- Content -->
        <section id="content" class="mb-12">
          <div class="bg-blue-50 dark:bg-gray-700 border-l-4 border-blue-400 dark:border-blue-500 p-6 rounded-r-lg mb-6">
            <h2 class="text-2xl font-bold text-blue-900 dark:text-blue-100 mb-2 flex items-center">
              <i class="material-icons mr-3 text-blue-600 dark:text-blue-400">description</i>
              Content & Pages
            </h2>
          </div>

          <div class="space-y-4">
            <div class="bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg p-5">
              <h4 class="font-semibold text-gray-900 dark:text-white mb-2">I can't create certain page types</h4>
              <p class="text-gray-700 dark:text-gray-300 text-sm">
                Some page types (Creatures, Magic Systems, Governments, etc.) are Premium-only. You can view and edit existing Premium pages, but creating new ones requires a <%= link_to 'Premium subscription', subscription_path, class: 'text-blue-600 dark:text-blue-400 hover:underline' %>.
              </p>
            </div>

            <div class="bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg p-5">
              <h4 class="font-semibold text-gray-900 dark:text-white mb-2">I accidentally deleted something important</h4>
              <p class="text-gray-700 dark:text-gray-300 text-sm">
                Check your <%= link_to 'Recycle Bin', recently_deleted_content_path, class: 'text-blue-600 dark:text-blue-400 hover:underline' %>. Deleted content stays there for 30 days before being permanently removed.
              </p>
            </div>

            <div class="bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg p-5">
              <h4 class="font-semibold text-gray-900 dark:text-white mb-2">My changes aren't saving</h4>
              <p class="text-gray-700 dark:text-gray-300 text-sm mb-2">
                Notebook.ai auto-saves your work, but if you're experiencing issues:
              </p>
              <ul class="text-gray-600 dark:text-gray-400 text-sm space-y-1 ml-4 list-disc list-inside">
                <li>Check your internet connection</li>
                <li>Try refreshing the page</li>
                <li>Clear your browser cache</li>
                <li>Make sure you're still logged in</li>
              </ul>
            </div>

            <div class="bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg p-5">
              <h4 class="font-semibold text-gray-900 dark:text-white mb-2">I can't find my content</h4>
              <p class="text-gray-700 dark:text-gray-300 text-sm mb-2">
                Try these steps:
              </p>
              <ul class="text-gray-600 dark:text-gray-400 text-sm space-y-1 ml-4 list-disc list-inside">
                <li>Make sure you're not in Universe Focus mode (or focus on the correct universe)</li>
                <li>Check your <%= link_to 'Archives', archive_path, class: 'text-blue-600 dark:text-blue-400 hover:underline' %> - you may have archived it</li>
                <li>Check the <%= link_to 'Recycle Bin', recently_deleted_content_path, class: 'text-blue-600 dark:text-blue-400 hover:underline' %></li>
                <li>Use the search function to find it by name</li>
              </ul>
            </div>
          </div>
        </section>

        <!-- Collaboration -->
        <section id="collaboration" class="mb-12">
          <div class="bg-teal-50 dark:bg-gray-700 border-l-4 border-teal-400 dark:border-teal-500 p-6 rounded-r-lg mb-6">
            <h2 class="text-2xl font-bold text-teal-900 dark:text-teal-100 mb-2 flex items-center">
              <i class="material-icons mr-3 text-teal-600 dark:text-teal-400">group</i>
              Collaboration
            </h2>
          </div>

          <div class="space-y-4">
            <div class="bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg p-5">
              <h4 class="font-semibold text-gray-900 dark:text-white mb-2">My collaborators can't see my universe</h4>
              <p class="text-gray-700 dark:text-gray-300 text-sm">
                Make sure you've properly invited them through the Contributors section of your universe page. They need to accept the invitation (check their email) to gain access.
              </p>
            </div>

            <div class="bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg p-5">
              <h4 class="font-semibold text-gray-900 dark:text-white mb-2">Collaborators can't create Premium pages</h4>
              <p class="text-gray-700 dark:text-gray-300 text-sm">
                Collaborators can only create Premium content types in universes owned by Premium subscribers. If you have Premium, make sure you're the owner of the universe, not just a collaborator.
              </p>
            </div>

            <div class="bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg p-5">
              <h4 class="font-semibold text-gray-900 dark:text-white mb-2">How do I remove a collaborator?</h4>
              <p class="text-gray-700 dark:text-gray-300 text-sm">
                Go to your universe page, find the Contributors section, and remove the collaborator you want to revoke access from. They will immediately lose access to the universe.
              </p>
            </div>
          </div>
        </section>

        <!-- Images -->
        <section id="images" class="mb-12">
          <div class="bg-yellow-50 dark:bg-gray-700 border-l-4 border-yellow-400 dark:border-yellow-500 p-6 rounded-r-lg mb-6">
            <h2 class="text-2xl font-bold text-yellow-900 dark:text-yellow-100 mb-2 flex items-center">
              <i class="material-icons mr-3 text-yellow-600 dark:text-yellow-400">image</i>
              Images & Storage
            </h2>
          </div>

          <div class="space-y-4">
            <div class="bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg p-5">
              <h4 class="font-semibold text-gray-900 dark:text-white mb-2">My image upload failed</h4>
              <p class="text-gray-700 dark:text-gray-300 text-sm mb-2">
                Common reasons for upload failures:
              </p>
              <ul class="text-gray-600 dark:text-gray-400 text-sm space-y-1 ml-4 list-disc list-inside">
                <li>File is too large (max 10MB per image)</li>
                <li>You've reached your storage limit (50MB free, 10GB Premium)</li>
                <li>Unsupported file format (use JPG, PNG, GIF, or WebP)</li>
                <li>Poor internet connection</li>
              </ul>
            </div>

            <div class="bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg p-5">
              <h4 class="font-semibold text-gray-900 dark:text-white mb-2">I'm running out of storage space</h4>
              <p class="text-gray-700 dark:text-gray-300 text-sm mb-2">
                To free up space:
              </p>
              <ul class="text-gray-600 dark:text-gray-400 text-sm space-y-1 ml-4 list-disc list-inside">
                <li>Visit <%= link_to 'Image Uploads', uploads_path, class: 'text-blue-600 dark:text-blue-400 hover:underline' %> to manage your files</li>
                <li>Delete unused images</li>
                <li>Compress large images before uploading</li>
                <li><%= link_to 'Upgrade to Premium', subscription_path, class: 'text-blue-600 dark:text-blue-400 hover:underline' %> for 10GB storage</li>
              </ul>
            </div>

            <div class="bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg p-5">
              <h4 class="font-semibold text-gray-900 dark:text-white mb-2">Images aren't displaying</h4>
              <p class="text-gray-700 dark:text-gray-300 text-sm">
                Try refreshing the page or clearing your browser cache. If images still don't load, the files may have been deleted or there may be a temporary server issue.
              </p>
            </div>
          </div>
        </section>

        <!-- Premium -->
        <section id="premium" class="mb-12">
          <div class="bg-indigo-50 dark:bg-gray-700 border-l-4 border-indigo-400 dark:border-indigo-500 p-6 rounded-r-lg mb-6">
            <h2 class="text-2xl font-bold text-indigo-900 dark:text-indigo-100 mb-2 flex items-center">
              <i class="material-icons mr-3 text-indigo-600 dark:text-indigo-400">star</i>
              Premium & Billing
            </h2>
          </div>

          <div class="space-y-4">
            <div class="bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg p-5">
              <h4 class="font-semibold text-gray-900 dark:text-white mb-2">I upgraded but don't have Premium features</h4>
              <p class="text-gray-700 dark:text-gray-300 text-sm">
                Try logging out and back in. If that doesn't work, check your <%= link_to 'Billing Page', subscription_path, class: 'text-blue-600 dark:text-blue-400 hover:underline' %> to confirm your subscription is active. Contact support if the issue persists.
              </p>
            </div>

            <div class="bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg p-5">
              <h4 class="font-semibold text-gray-900 dark:text-white mb-2">What happens to my content if I cancel?</h4>
              <p class="text-gray-700 dark:text-gray-300 text-sm">
                You keep full access to all content you've created, including Premium page types. You just can't create new Premium pages until you resubscribe.
              </p>
            </div>

            <div class="bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg p-5">
              <h4 class="font-semibold text-gray-900 dark:text-white mb-2">How do I cancel my subscription?</h4>
              <p class="text-gray-700 dark:text-gray-300 text-sm">
                Visit your <%= link_to 'Billing Page', subscription_path, class: 'text-blue-600 dark:text-blue-400 hover:underline' %> and click "Downgrade" to cancel. For more details, see the <%= link_to 'Billing FAQ', billing_faq_path, class: 'text-blue-600 dark:text-blue-400 hover:underline' %>.
              </p>
            </div>
          </div>
        </section>

        <!-- Browser -->
        <section id="browser" class="mb-12">
          <div class="bg-gray-100 dark:bg-gray-700 border-l-4 border-gray-400 dark:border-gray-500 p-6 rounded-r-lg mb-6">
            <h2 class="text-2xl font-bold text-gray-900 dark:text-white mb-2 flex items-center">
              <i class="material-icons mr-3 text-gray-600 dark:text-gray-400">computer</i>
              Browser & Technical
            </h2>
          </div>

          <div class="space-y-4">
            <div class="bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg p-5">
              <h4 class="font-semibold text-gray-900 dark:text-white mb-2">Which browsers are supported?</h4>
              <p class="text-gray-700 dark:text-gray-300 text-sm">
                Notebook.ai works best on modern browsers: Chrome, Firefox, Safari, and Edge. For the best experience, keep your browser updated to the latest version.
              </p>
            </div>

            <div class="bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg p-5">
              <h4 class="font-semibold text-gray-900 dark:text-white mb-2">The site is loading slowly</h4>
              <p class="text-gray-700 dark:text-gray-300 text-sm mb-2">
                Try these steps:
              </p>
              <ul class="text-gray-600 dark:text-gray-400 text-sm space-y-1 ml-4 list-disc list-inside">
                <li>Check your internet connection</li>
                <li>Clear your browser cache and cookies</li>
                <li>Disable browser extensions temporarily</li>
                <li>Try a different browser</li>
              </ul>
            </div>

            <div class="bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg p-5">
              <h4 class="font-semibold text-gray-900 dark:text-white mb-2">I'm seeing an error message</h4>
              <p class="text-gray-700 dark:text-gray-300 text-sm">
                Try refreshing the page first. If the error persists, please <%= link_to 'report the problem', 'https://docs.google.com/forms/d/e/1FAIpQLSe0jnqJlcPJDqwogGere5j8-8F1nSGGYkzbsI-XkOeMnGwLrA/viewform', target: '_blank', class: 'text-blue-600 dark:text-blue-400 hover:underline' %> with details about what you were doing when it occurred.
              </p>
            </div>
          </div>
        </section>

        <!-- Contact -->
        <section id="contact" class="mb-12">
          <div class="bg-blue-50 dark:bg-gray-700 border border-blue-200 dark:border-blue-700 rounded-lg p-6">
            <h3 class="font-semibold text-blue-900 dark:text-blue-100 mb-3 flex items-center">
              <i class="material-icons mr-2 text-blue-600 dark:text-blue-400">support</i>
              Still Need Help?
            </h3>
            <p class="text-blue-800 dark:text-blue-200 mb-4">
              If your question wasn't answered here, we're happy to help!
            </p>
            <div class="flex flex-wrap gap-3">
              <a href="mailto:andrew@indentlabs.com" class="inline-flex items-center px-4 py-2 bg-blue-600 dark:bg-blue-500 text-white rounded-lg hover:bg-blue-700 dark:hover:bg-blue-600 transition-colors duration-200">
                <i class="material-icons mr-2">email</i>
                Email Support
              </a>
              <%= link_to 'https://www.notebook.ai/forum/site-support', target: '_blank', class: 'inline-flex items-center px-4 py-2 bg-white dark:bg-gray-700 text-gray-700 dark:text-gray-200 border border-gray-300 dark:border-gray-600 rounded-lg hover:bg-gray-50 dark:hover:bg-gray-600 transition-colors duration-200' do %>
                <i class="material-icons mr-2">forum</i>
                Ask on Forums
              <% end %>
              <%= link_to 'https://docs.google.com/forms/d/e/1FAIpQLSe0jnqJlcPJDqwogGere5j8-8F1nSGGYkzbsI-XkOeMnGwLrA/viewform', target: '_blank', class: 'inline-flex items-center px-4 py-2 bg-white dark:bg-gray-700 text-gray-700 dark:text-gray-200 border border-gray-300 dark:border-gray-600 rounded-lg hover:bg-gray-50 dark:hover:bg-gray-600 transition-colors duration-200' do %>
                <i class="material-icons mr-2">bug_report</i>
                Report a Bug
              <% end %>
            </div>
          </div>
        </section>

      </div>
    </div>
  </div>
</div>
