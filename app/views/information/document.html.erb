        <p class="leading-relaxed">total words written</p>
      </div>
    </div>
    <div class="lg:w-1/2 sm:w-1/3 w-full rounded-lg overflow-hidden mt-6 sm:mt-0 bg-gradient-to-r from-teal-600 to-teal-800 flex items-center justify-center h-64">
      <i class="material-icons text-white text-9xl"><%= @content_type.icon %></i>
    </div>
  </div>
</section>

