<%
  singular_class_name   = @content_type.name
  pluralized_class_name = @content_type.name.pluralize
  premium_page          = false # Documents are free to create

  set_meta_tags title: "Capture Ideas. Craft Stories.",
                description: "Write with purpose using Notebook.ai's powerful document editor. Organize with folders, track your progress, and connect your writing to your worldbuilding.",
                og: {
                  title: "Capture Ideas. Craft Stories. on Notebook.ai"
                }
%>

<%# ========== SECTION 1: HERO (Enhanced - 40vh) ========== %>
<section class="text-teal-900" style="height: 40vh;">
  <div class="h-full bg-right-bottom bg-cover flex shadow-lg bg-gradient-to-r from-teal-600 to-teal-800">
    <div class="container mx-auto p-4 flex items-center z-10">
      <div class="text-center w-full">
        <div class="text-white tracking-widest py-4 px-5 my-5">
          <div class="mb-3 text-4xl md:text-6xl" style="text-shadow: black 0px 0px 10px;">
            <i class="material-icons text-5xl <%= @content_type.text_color %>"><%= @content_type.icon %></i>
            Capture Ideas. Craft Stories.
          </div>
          <div class="leading-normal text-xl md:text-2xl" style="text-shadow: black 0px 0px 10px;">
            Write, organize, and connect your stories to the worlds you've built
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<%# ========== SECTION 2: VALUE PROPOSITION ========== %>
<section class="text-gray-600 dark:text-gray-300 body-font">
  <div class="container mx-auto flex px-5 py-16 md:flex-row flex-col items-center">
    <div class="lg:max-w-lg lg:w-full md:w-1/2 w-5/6 mb-10 md:mb-0">
      <div class="bg-gradient-to-br from-teal-500 to-teal-700 rounded-lg p-8 flex items-center justify-center h-64">
        <i class="material-icons text-white text-9xl"><%= @content_type.icon %></i>
      </div>
    </div>
    <div class="lg:flex-grow md:w-1/2 lg:pl-24 md:pl-16 flex flex-col md:items-start md:text-left items-center text-center">
      <h1 class="title-font sm:text-4xl text-3xl mb-4 font-medium text-gray-900 dark:text-white">
        Your Writing,
        <span class="<%= @content_type.text_color %>">Connected to Your World</span>
      </h1>
      <p class="bg-teal-50 dark:bg-teal-900 py-4 px-4 my-2 rounded border border-teal-200 dark:border-teal-700">
        <em>
          Notebook.ai's Documents are more than just a text editor. They're a writing environment
          designed to keep your worldbuilding at your fingertips while you craft your stories.
        </em>
      </p>
      <ul class="my-4 space-y-2">
        <li class="flex items-center">
          <i class="material-icons text-teal-500 mr-2">check_circle</i>
          <span><strong>Unlimited free documents</strong> &mdash; no credit card required</span>
        </li>
        <li class="flex items-center">
          <i class="material-icons text-teal-500 mr-2">check_circle</i>
          <span><strong>Folder organization</strong> &mdash; keep your writing structured</span>
        </li>
        <li class="flex items-center">
          <i class="material-icons text-teal-500 mr-2">check_circle</i>
          <span><strong>Distraction-free writing</strong> &mdash; focus on what matters</span>
        </li>
      </ul>
    </div>
  </div>
</section>

<%# ========== SECTION 3: CORE FEATURES (3 Cards) ========== %>
<section class="text-gray-600 dark:text-gray-300 body-font bg-gray-50 dark:bg-gray-900">
  <div class="container px-5 py-16 mx-auto">
    <div class="flex flex-wrap sm:-m-4 -mx-4 -mb-10 -mt-4 md:space-y-0 space-y-6">
      <div class="p-8 lg:w-1/3 flex flex-col items-center">
        <div class="bg-white dark:bg-gray-800 border border-teal-100 dark:border-gray-700 rounded-lg p-4 text-center h-full shadow-sm">
          <div class="w-20 h-20 md:mt-4 inline-flex items-center justify-center rounded-full bg-teal-100 dark:bg-teal-900 mb-5 flex-shrink-0">
            <i class="material-icons text-teal-600 dark:text-teal-400 text-5xl">folder</i>
          </div>
          <div class="flex-grow text-left px-4">
            <h2 class="text-gray-900 dark:text-white text-lg title-font font-medium mb-3">
              Organize With Folders
            </h2>
            <p class="leading-relaxed text-base my-2">
              Create a folder structure that matches how you think. Nest folders within folders
              to organize chapters, series, or any system that works for you.
            </p>
            <p class="leading-relaxed text-base my-2 bg-teal-50 dark:bg-teal-900 py-2 px-4 -mx-4 my-4 border border-teal-100 dark:border-teal-800 rounded">
              Drag and drop documents between folders to reorganize your work instantly.
            </p>
          </div>
        </div>
      </div>
      <div class="p-8 lg:w-1/3 flex flex-col items-center">
        <div class="bg-white dark:bg-gray-800 border border-teal-100 dark:border-gray-700 rounded-lg p-4 text-center h-full shadow-sm">
          <div class="w-20 h-20 md:mt-4 inline-flex items-center justify-center rounded-full bg-teal-100 dark:bg-teal-900 mb-5 flex-shrink-0">
            <i class="material-icons text-teal-600 dark:text-teal-400 text-5xl">track_changes</i>
          </div>
          <div class="flex-grow text-left px-4">
            <h2 class="text-gray-900 dark:text-white text-lg title-font font-medium mb-3">
              Track Your Progress
            </h2>
            <p class="leading-relaxed text-base my-2">
              Move documents through an 8-step workflow from initial idea to complete.
              Always know exactly where each piece of writing stands.
            </p>
            <p class="leading-relaxed text-base my-2 bg-teal-50 dark:bg-teal-900 py-2 px-4 -mx-4 my-4 border border-teal-100 dark:border-teal-800 rounded">
              Filter your documents by status to focus on what needs attention.
            </p>
          </div>
        </div>
      </div>
      <div class="p-8 lg:w-1/3 flex flex-col items-center">
        <div class="bg-white dark:bg-gray-800 border border-teal-100 dark:border-gray-700 rounded-lg p-4 text-center h-full shadow-sm">
          <div class="w-20 h-20 md:mt-4 inline-flex items-center justify-center rounded-full bg-teal-100 dark:bg-teal-900 mb-5 flex-shrink-0">
            <i class="material-icons text-teal-600 dark:text-teal-400 text-5xl">star</i>
          </div>
          <div class="flex-grow text-left px-4">
            <h2 class="text-gray-900 dark:text-white text-lg title-font font-medium mb-3">
              Free Forever
            </h2>
            <p class="leading-relaxed text-base my-2">
              Create unlimited documents on Notebook.ai without ever paying a dime. No credit card required,
              no trial period, no catch.
            </p>
            <p class="leading-relaxed text-base my-2 bg-teal-50 dark:bg-teal-900 py-2 px-4 -mx-4 my-4 border border-teal-100 dark:border-teal-800 rounded">
              Your documents are yours forever &mdash; we'll never lock you out of your own writing.
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<%# ========== SECTION 4: WRITING ENVIRONMENT (Dark Section) ========== %>
<section class="text-white body-font bg-gray-900">
  <div class="container px-5 py-20 mx-auto">
    <div class="text-center mb-12">
      <h1 class="sm:text-4xl text-3xl font-medium title-font mb-4">
        A Writing Environment
        <span class="text-teal-400">Built for Focus</span>
      </h1>
      <p class="text-gray-400 lg:w-2/3 mx-auto leading-relaxed text-lg">
        Every feature is designed to keep you in the flow of writing without distractions.
      </p>
    </div>

    <div class="flex flex-wrap -m-4">
      <div class="p-4 md:w-1/2 lg:w-1/4">
        <div class="bg-gray-800 border border-teal-600 rounded-lg p-6 h-full">
          <div class="flex items-center mb-4">
            <i class="material-icons text-teal-400 mr-3">save</i>
            <h3 class="text-lg font-medium">Autosave</h3>
          </div>
          <p class="text-gray-400">
            Never lose your work. Documents save automatically as you type, so you can focus on writing.
          </p>
        </div>
      </div>
      <div class="p-4 md:w-1/2 lg:w-1/4">
        <div class="bg-gray-800 border border-teal-600 rounded-lg p-6 h-full">
          <div class="flex items-center mb-4">
            <i class="material-icons text-teal-400 mr-3">text_fields</i>
            <h3 class="text-lg font-medium">Word Count</h3>
          </div>
          <p class="text-gray-400">
            Track your word count in real-time. Set goals and watch your progress grow.
          </p>
        </div>
      </div>
      <div class="p-4 md:w-1/2 lg:w-1/4">
        <div class="bg-gray-800 border border-teal-600 rounded-lg p-6 h-full">
          <div class="flex items-center mb-4">
            <i class="material-icons text-teal-400 mr-3">local_fire_department</i>
            <h3 class="text-lg font-medium">Writing Streak</h3>
          </div>
          <p class="text-gray-400">
            Build a writing habit. Track your consecutive days of writing to stay motivated.
          </p>
        </div>
      </div>
      <div class="p-4 md:w-1/2 lg:w-1/4">
        <div class="bg-gray-800 border border-teal-600 rounded-lg p-6 h-full">
          <div class="flex items-center mb-4">
            <i class="material-icons text-teal-400 mr-3">visibility_off</i>
            <h3 class="text-lg font-medium">Distraction-Free</h3>
          </div>
          <p class="text-gray-400">
            A clean, minimal interface that puts your words front and center.
          </p>
        </div>
      </div>
    </div>

    <div class="mt-12 text-center">
      <div class="inline-block bg-gray-800 rounded-lg p-6 border border-gray-700">
        <h4 class="text-teal-400 font-medium mb-4">Writing Statistics at a Glance</h4>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-6 text-sm">
          <div class="text-center">
            <div class="text-white font-medium">Word Count</div>
            <div class="text-gray-500">Real-time tracking</div>
          </div>
          <div class="text-center">
            <div class="text-white font-medium">Reading Time</div>
            <div class="text-gray-500">Estimated duration</div>
          </div>
          <div class="text-center">
            <div class="text-white font-medium">Character Count</div>
            <div class="text-gray-500">With & without spaces</div>
          </div>
          <div class="text-center">
            <div class="text-white font-medium">Last Updated</div>
            <div class="text-gray-500">Automatic timestamps</div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<%# ========== SECTION 5: STATUS WORKFLOW ========== %>
<section class="text-gray-600 dark:text-gray-300 body-font">
  <div class="container px-5 py-20 mx-auto">
    <div class="text-center mb-12">
      <h1 class="sm:text-4xl text-3xl font-medium title-font mb-4 text-gray-900 dark:text-white">
        Track Every Document's
        <span class="<%= @content_type.text_color %>">Journey</span>
      </h1>
      <p class="text-gray-600 dark:text-gray-400 lg:w-2/3 mx-auto leading-relaxed text-lg">
        From a spark of inspiration to a finished piece, track exactly where each document stands in your writing process.
      </p>
    </div>

    <div class="flex flex-wrap justify-center items-center gap-2 mb-8">
      <div class="flex items-center bg-gray-100 dark:bg-gray-800 text-gray-600 dark:text-gray-400 px-3 py-2 rounded-lg">
        <i class="material-icons mr-2 text-sm">lightbulb</i>
        <span>Idea</span>
      </div>
      <div class="flex items-center">
        <i class="material-icons text-gray-400">arrow_forward</i>
      </div>
      <div class="flex items-center bg-yellow-100 dark:bg-yellow-900 text-yellow-800 dark:text-yellow-200 px-3 py-2 rounded-lg">
        <i class="material-icons mr-2 text-sm">note</i>
        <span>Draft</span>
      </div>
      <div class="flex items-center">
        <i class="material-icons text-gray-400">arrow_forward</i>
      </div>
      <div class="flex items-center bg-blue-100 dark:bg-blue-900 text-blue-800 dark:text-blue-200 px-3 py-2 rounded-lg">
        <i class="material-icons mr-2 text-sm">edit</i>
        <span>Writing</span>
      </div>
      <div class="flex items-center">
        <i class="material-icons text-gray-400">arrow_forward</i>
      </div>
      <div class="flex items-center bg-orange-100 dark:bg-orange-900 text-orange-800 dark:text-orange-200 px-3 py-2 rounded-lg">
        <i class="material-icons mr-2 text-sm">rate_review</i>
        <span>Revising</span>
      </div>
    </div>
    <div class="flex flex-wrap justify-center items-center gap-2">
      <div class="flex items-center bg-purple-100 dark:bg-purple-900 text-purple-800 dark:text-purple-200 px-3 py-2 rounded-lg">
        <i class="material-icons mr-2 text-sm">spellcheck</i>
        <span>Editing</span>
      </div>
      <div class="flex items-center">
        <i class="material-icons text-gray-400">arrow_forward</i>
      </div>
      <div class="flex items-center bg-indigo-100 dark:bg-indigo-900 text-indigo-800 dark:text-indigo-200 px-3 py-2 rounded-lg">
        <i class="material-icons mr-2 text-sm">send</i>
        <span>Submitting</span>
      </div>
      <div class="flex items-center">
        <i class="material-icons text-gray-400">arrow_forward</i>
      </div>
      <div class="flex items-center bg-green-100 dark:bg-green-900 text-green-800 dark:text-green-200 px-3 py-2 rounded-lg">
        <i class="material-icons mr-2 text-sm">menu_book</i>
        <span>Published</span>
      </div>
      <div class="flex items-center">
        <i class="material-icons text-gray-400">arrow_forward</i>
      </div>
      <div class="flex items-center bg-teal-100 dark:bg-teal-900 text-teal-800 dark:text-teal-200 px-3 py-2 rounded-lg">
        <i class="material-icons mr-2 text-sm">check_circle</i>
        <span>Complete</span>
      </div>
    </div>

    <div class="mt-12 text-center">
      <p class="text-gray-500 dark:text-gray-400">
        Update status with a single click. Filter your document list by status to focus on what needs attention.
      </p>
    </div>
  </div>
</section>

<%# ========== SECTION 6: WORLDBUILDING INTEGRATION ========== %>
<section class="text-gray-600 dark:text-gray-300 body-font bg-gradient-to-br from-teal-50 to-cyan-50 dark:from-gray-900 dark:to-gray-800">
  <div class="container px-5 py-20 mx-auto">
    <div class="text-center mb-12">
      <h1 class="sm:text-4xl text-3xl font-medium title-font mb-4 text-gray-900 dark:text-white">
        Write With Your World
        <span class="<%= @content_type.text_color %>">At Your Fingertips</span>
      </h1>
      <p class="text-gray-600 dark:text-gray-400 lg:w-2/3 mx-auto leading-relaxed text-lg">
        Link characters, locations, items, and more directly to your documents.
        Reference your worldbuilding without leaving your draft.
      </p>
    </div>

    <div class="flex flex-wrap items-center">
      <div class="lg:w-1/2 w-full mb-10 lg:mb-0 lg:pr-12">
        <div class="bg-white dark:bg-gray-800 rounded-lg shadow-lg border border-teal-200 dark:border-gray-700 p-6">
          <h3 class="text-lg font-medium text-gray-900 dark:text-white mb-4">
            <i class="material-icons <%= @content_type.text_color %> mr-2 align-middle"><%= @content_type.icon %></i>
            Link Worldbuilding Pages
          </h3>
          <ul class="space-y-3">
            <li class="flex items-start">
              <i class="material-icons text-green-500 mr-2 text-sm mt-1">check_circle</i>
              <span><strong>Link characters</strong> &mdash; See character details while writing their scenes</span>
            </li>
            <li class="flex items-start">
              <i class="material-icons text-green-500 mr-2 text-sm mt-1">check_circle</i>
              <span><strong>Connect locations</strong> &mdash; Never forget a setting detail again</span>
            </li>
            <li class="flex items-start">
              <i class="material-icons text-green-500 mr-2 text-sm mt-1">check_circle</i>
              <span><strong>Reference items</strong> &mdash; Keep magic systems and artifacts consistent</span>
            </li>
            <li class="flex items-start">
              <i class="material-icons text-green-500 mr-2 text-sm mt-1">check_circle</i>
              <span><strong>Link to any page</strong> &mdash; Connect creatures, languages, religions, and more</span>
            </li>
            <li class="flex items-start">
              <i class="material-icons text-green-500 mr-2 text-sm mt-1">check_circle</i>
              <span><strong>Universe organization</strong> &mdash; Keep documents organized within their worlds</span>
            </li>
          </ul>
        </div>
      </div>
      <div class="lg:w-1/2 w-full">
        <div class="text-center lg:text-left">
          <div class="inline-flex flex-wrap gap-4 justify-center lg:justify-start">
            <div class="flex items-center bg-white dark:bg-gray-800 rounded-lg px-4 py-2 shadow-sm border border-gray-200 dark:border-gray-700">
              <i class="material-icons <%= Character.text_color %> mr-2"><%= Character.icon %></i>
              <span>Characters</span>
            </div>
            <div class="flex items-center bg-white dark:bg-gray-800 rounded-lg px-4 py-2 shadow-sm border border-gray-200 dark:border-gray-700">
              <i class="material-icons <%= Location.text_color %> mr-2"><%= Location.icon %></i>
              <span>Locations</span>
            </div>
            <div class="flex items-center bg-white dark:bg-gray-800 rounded-lg px-4 py-2 shadow-sm border border-gray-200 dark:border-gray-700">
              <i class="material-icons <%= Item.text_color %> mr-2"><%= Item.icon %></i>
              <span>Items</span>
            </div>
            <div class="flex items-center bg-white dark:bg-gray-800 rounded-lg px-4 py-2 shadow-sm border border-gray-200 dark:border-gray-700">
              <i class="material-icons <%= Universe.text_color %> mr-2"><%= Universe.icon %></i>
              <span>Universes</span>
            </div>
            <div class="flex items-center bg-white dark:bg-gray-800 rounded-lg px-4 py-2 shadow-sm border border-gray-200 dark:border-gray-700">
              <i class="material-icons <%= Creature.text_color %> mr-2"><%= Creature.icon %></i>
              <span>Creatures</span>
            </div>
          </div>
          <p class="mt-6 text-gray-500 dark:text-gray-400">
            Plus 30+ more worldbuilding page types to connect to your documents.
          </p>
        </div>
      </div>
    </div>
  </div>
</section>

<%# ========== SECTION 7: AI ANALYSIS (Premium) ========== %>
