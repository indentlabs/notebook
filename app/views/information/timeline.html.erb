<%
  singular_class_name   = @content_type.name
  pluralized_class_name = @content_type.name.pluralize
  premium_page          = !User.new.can_create?(@content_type)

  set_meta_tags title: "Build Your Story. Event by Event.",
                description: "Track events, plot points, and chronological stories within your fictional world with Notebook.ai's powerful timeline tools.",
                image_src: URI.join(root_url, asset_path("card-headers/#{pluralized_class_name.downcase}.webp")),
                og: {
                  title: "Build Your Story. Event by Event. on Notebook.ai"
                }
%>

<%# ========== SECTION 1: HERO (Enhanced - 40vh) ========== %>
<section class="text-green-900" style="height: 40vh;">
  <div class="h-full bg-right-bottom bg-cover flex shadow-lg bg-gradient-to-r from-green-600 to-green-800">
    <div class="container mx-auto p-4 flex items-center z-10">
      <div class="text-center w-full">
        <div class="text-white tracking-widest py-4 px-5 my-5">
          <div class="mb-3 text-4xl md:text-6xl" style="text-shadow: black 0px 0px 10px;">
            <i class="material-icons text-5xl <%= @content_type.text_color %>"><%= @content_type.icon %></i>
            Build Your Story. Event by Event.
          </div>
          <div class="leading-normal text-xl md:text-2xl" style="text-shadow: black 0px 0px 10px;">
            Track events, plot points, and chronological stories within your fictional world
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<%# ========== SECTION 2: VALUE PROPOSITION ========== %>
<section class="text-gray-600 dark:text-gray-300 body-font">
  <div class="container mx-auto flex px-5 py-16 md:flex-row flex-col items-center">
    <div class="lg:max-w-lg lg:w-full md:w-1/2 w-5/6 mb-10 md:mb-0">
      <div class="bg-gradient-to-br from-green-500 to-green-700 rounded-lg p-8 flex items-center justify-center h-64">
        <i class="material-icons text-white text-9xl"><%= @content_type.icon %></i>
      </div>
    </div>
    <div class="lg:flex-grow md:w-1/2 lg:pl-24 md:pl-16 flex flex-col md:items-start md:text-left items-center text-center">
      <h1 class="title-font sm:text-4xl text-3xl mb-4 font-medium text-gray-900 dark:text-white">
        Master Your Narrative's
        <span class="<%= @content_type.text_color %>">Flow of Time</span>
      </h1>
      <p class="bg-green-50 dark:bg-green-900 py-4 px-4 my-2 rounded border border-green-200 dark:border-green-700">
        <em>
          <%= t("content_descriptions.#{singular_class_name.downcase}") %>
        </em>
      </p>
      <ul class="my-4 space-y-2">
        <li class="flex items-center">
          <i class="material-icons text-green-500 mr-2">check_circle</i>
          <span><strong>13 narrative event types</strong> &mdash; from setup to resolution</span>
        </li>
        <li class="flex items-center">
          <i class="material-icons text-green-500 mr-2">check_circle</i>
          <span><strong>Entity linking</strong> &mdash; connect events to characters, locations, and more</span>
        </li>
        <li class="flex items-center">
          <i class="material-icons text-green-500 mr-2">check_circle</i>
          <span><strong>Flexible date tracking</strong> &mdash; real or fictional calendars</span>
        </li>
      </ul>
    </div>
  </div>
</section>

<%# ========== SECTION 3: CORE FEATURES (3 Cards) ========== %>
<section class="text-gray-600 dark:text-gray-300 body-font bg-gray-50 dark:bg-gray-900">
  <div class="container px-5 py-16 mx-auto">
    <div class="flex flex-wrap sm:-m-4 -mx-4 -mb-10 -mt-4 md:space-y-0 space-y-6">
      <div class="p-8 lg:w-1/3 flex flex-col items-center">
        <div class="bg-white dark:bg-gray-800 border border-green-100 dark:border-gray-700 rounded-lg p-4 text-center h-full shadow-sm">
          <div class="w-20 h-20 md:mt-4 inline-flex items-center justify-center rounded-full bg-green-100 dark:bg-green-900 mb-5 flex-shrink-0">
            <i class="material-icons text-green-600 dark:text-green-400 text-5xl">event</i>
          </div>
          <div class="flex-grow text-left px-4">
            <h2 class="text-gray-900 dark:text-white text-lg title-font font-medium mb-3">
              Narrative Event Types
            </h2>
            <p class="leading-relaxed text-base my-2">
              Categorize your events by their narrative purpose. Track inciting incidents, complications,
              revelations, climaxes, and more to understand your story's structure.
            </p>
            <p class="leading-relaxed text-base my-2 bg-green-50 dark:bg-green-900 py-2 px-4 -mx-4 my-4 border border-green-100 dark:border-green-800 rounded">
              Each event type has its own icon and color for visual storytelling at a glance.
            </p>
          </div>
        </div>
      </div>
      <div class="p-8 lg:w-1/3 flex flex-col items-center">
        <div class="bg-white dark:bg-gray-800 border border-green-100 dark:border-gray-700 rounded-lg p-4 text-center h-full shadow-sm">
          <div class="w-20 h-20 md:mt-4 inline-flex items-center justify-center rounded-full bg-green-100 dark:bg-green-900 mb-5 flex-shrink-0">
            <i class="material-icons text-green-600 dark:text-green-400 text-5xl">link</i>
          </div>
          <div class="flex-grow text-left px-4">
            <h2 class="text-gray-900 dark:text-white text-lg title-font font-medium mb-3">
              Entity Linking
            </h2>
            <p class="leading-relaxed text-base my-2">
              Connect any worldbuilding page to timeline events. Link characters, locations, items,
              and more to build a rich, interconnected narrative web.
            </p>
            <p class="leading-relaxed text-base my-2 bg-green-50 dark:bg-green-900 py-2 px-4 -mx-4 my-4 border border-green-100 dark:border-green-800 rounded">
              See at a glance which characters appear in which events.
            </p>
          </div>
        </div>
      </div>
      <div class="p-8 lg:w-1/3 flex flex-col items-center">
        <div class="bg-white dark:bg-gray-800 border border-green-100 dark:border-gray-700 rounded-lg p-4 text-center h-full shadow-sm">
          <div class="w-20 h-20 md:mt-4 inline-flex items-center justify-center rounded-full bg-green-100 dark:bg-green-900 mb-5 flex-shrink-0">
            <i class="material-icons text-green-600 dark:text-green-400 text-5xl">star</i>
          </div>
          <div class="flex-grow text-left px-4">
            <h2 class="text-gray-900 dark:text-white text-lg title-font font-medium mb-3">
              <%= (premium_page) ? "Premium Feature" : "Free Forever" %>
            </h2>
            <% if premium_page %>
              <p class="leading-relaxed text-base my-2">
                Timelines are a Premium feature, giving advanced storytellers powerful tools to
                organize complex narratives and track character arcs across time.
              </p>
              <p class="leading-relaxed text-base my-2 bg-green-50 dark:bg-green-900 py-2 px-4 -mx-4 my-4 border border-green-100 dark:border-green-800 rounded">
                Your timelines are yours forever &mdash; even if you downgrade later.
              </p>
            <% else %>
              <p class="leading-relaxed text-base my-2">
                Create unlimited timelines on Notebook.ai without ever paying a dime. No credit card required,
                no trial period, no catch.
              </p>
              <p class="leading-relaxed text-base my-2 bg-green-50 dark:bg-green-900 py-2 px-4 -mx-4 my-4 border border-green-100 dark:border-green-800 rounded">
                Your timelines are yours forever &mdash; we'll never lock you out.
              </p>
            <% end %>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<%# ========== SECTION 4: NARRATIVE EVENT TYPES (Dark Section) ========== %>
<section class="text-white body-font bg-gray-900">
  <div class="container px-5 py-20 mx-auto">
    <div class="text-center mb-16">
      <h1 class="sm:text-4xl text-3xl font-medium title-font mb-4">
        13 Narrative Event Types to
        <span class="text-green-400">Structure Your Story</span>
      </h1>
      <p class="text-gray-400 lg:w-2/3 mx-auto leading-relaxed text-lg">
        Every great story follows a structure. Track your narrative beats with purpose-built event types
        that help you understand your story's flow.
      </p>
    </div>

    <%# Story Structure Visual Timeline %>
    <div class="max-w-6xl mx-auto">
      <%# Beginning %>
      <div class="mb-8">
        <div class="flex items-center mb-4">
          <div class="h-px flex-grow bg-gradient-to-r from-transparent to-blue-500"></div>
          <span class="px-4 text-blue-400 font-medium uppercase tracking-wider text-sm">Beginning</span>
          <div class="h-px flex-grow bg-gradient-to-l from-transparent to-blue-500"></div>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
          <div class="group bg-gray-800 rounded-xl p-5 border-l-4 border-gray-500 hover:border-gray-400 transition-all hover:bg-gray-750 hover:shadow-lg">
            <div class="flex items-center mb-3">
              <div class="w-10 h-10 rounded-full bg-gray-700 flex items-center justify-center mr-3">
                <i class="material-icons text-gray-400">circle</i>
              </div>
              <h3 class="font-semibold text-lg">General</h3>
            </div>
            <p class="text-gray-400 text-sm leading-relaxed">Basic events and worldbuilding moments</p>
          </div>
          <div class="group bg-gray-800 rounded-xl p-5 border-l-4 border-blue-500 hover:border-blue-400 transition-all hover:bg-gray-750 hover:shadow-lg">
            <div class="flex items-center mb-3">
              <div class="w-10 h-10 rounded-full bg-blue-900 flex items-center justify-center mr-3">
                <i class="material-icons text-blue-400">flag</i>
              </div>
              <h3 class="font-semibold text-lg">Setup</h3>
            </div>
            <p class="text-gray-400 text-sm leading-relaxed">Establishing the world and characters</p>
          </div>
          <div class="group bg-gray-800 rounded-xl p-5 border-l-4 border-indigo-500 hover:border-indigo-400 transition-all hover:bg-gray-750 hover:shadow-lg">
            <div class="flex items-center mb-3">
              <div class="w-10 h-10 rounded-full bg-indigo-900 flex items-center justify-center mr-3">
                <i class="material-icons text-indigo-400">info</i>
              </div>
              <h3 class="font-semibold text-lg">Exposition</h3>
            </div>
            <p class="text-gray-400 text-sm leading-relaxed">Background information and context</p>
          </div>
          <div class="group bg-gray-800 rounded-xl p-5 border-l-4 border-yellow-500 hover:border-yellow-400 transition-all hover:bg-gray-750 hover:shadow-lg">
            <div class="flex items-center mb-3">
              <div class="w-10 h-10 rounded-full bg-yellow-900 flex items-center justify-center mr-3">
                <i class="material-icons text-yellow-400">bolt</i>
              </div>
              <h3 class="font-semibold text-lg">Inciting Incident</h3>
            </div>
            <p class="text-gray-400 text-sm leading-relaxed">The event that sets everything in motion</p>
          </div>
        </div>
      </div>

      <%# Rising Action %>
      <div class="mb-8">
        <div class="flex items-center mb-4">
          <div class="h-px flex-grow bg-gradient-to-r from-transparent to-orange-500"></div>
          <span class="px-4 text-orange-400 font-medium uppercase tracking-wider text-sm">Rising Action</span>
          <div class="h-px flex-grow bg-gradient-to-l from-transparent to-orange-500"></div>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
          <div class="group bg-gray-800 rounded-xl p-5 border-l-4 border-orange-500 hover:border-orange-400 transition-all hover:bg-gray-750 hover:shadow-lg">
            <div class="flex items-center mb-3">
              <div class="w-10 h-10 rounded-full bg-orange-900 flex items-center justify-center mr-3">
                <i class="material-icons text-orange-400">warning</i>
              </div>
              <h3 class="font-semibold text-lg">Complication</h3>
            </div>
            <p class="text-gray-400 text-sm leading-relaxed">Things getting more difficult</p>
          </div>
          <div class="group bg-gray-800 rounded-xl p-5 border-l-4 border-red-500 hover:border-red-400 transition-all hover:bg-gray-750 hover:shadow-lg">
            <div class="flex items-center mb-3">
              <div class="w-10 h-10 rounded-full bg-red-900 flex items-center justify-center mr-3">
                <i class="material-icons text-red-400">block</i>
              </div>
              <h3 class="font-semibold text-lg">Obstacle</h3>
            </div>
            <p class="text-gray-400 text-sm leading-relaxed">Barriers the protagonist must overcome</p>
          </div>
          <div class="group bg-gray-800 rounded-xl p-5 border-l-4 border-red-600 hover:border-red-500 transition-all hover:bg-gray-750 hover:shadow-lg">
            <div class="flex items-center mb-3">
              <div class="w-10 h-10 rounded-full bg-red-900 flex items-center justify-center mr-3">
                <i class="material-icons text-red-500">gavel</i>
              </div>
              <h3 class="font-semibold text-lg">Conflict</h3>
            </div>
            <p class="text-gray-400 text-sm leading-relaxed">Direct confrontation and struggle</p>
          </div>
          <div class="group bg-gray-800 rounded-xl p-5 border-l-4 border-green-500 hover:border-green-400 transition-all hover:bg-gray-750 hover:shadow-lg">
            <div class="flex items-center mb-3">
              <div class="w-10 h-10 rounded-full bg-green-900 flex items-center justify-center mr-3">
                <i class="material-icons text-green-400">trending_up</i>
              </div>
              <h3 class="font-semibold text-lg">Progress</h3>
            </div>
            <p class="text-gray-400 text-sm leading-relaxed">Moving toward the goal</p>
          </div>
        </div>
      </div>

      <%# Climax & Turning Points %>
      <div class="mb-8">
        <div class="flex items-center mb-4">
          <div class="h-px flex-grow bg-gradient-to-r from-transparent to-amber-500"></div>
          <span class="px-4 text-amber-400 font-medium uppercase tracking-wider text-sm">Climax & Turning Points</span>
          <div class="h-px flex-grow bg-gradient-to-l from-transparent to-amber-500"></div>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
          <div class="group bg-gray-800 rounded-xl p-5 border-l-4 border-purple-500 hover:border-purple-400 transition-all hover:bg-gray-750 hover:shadow-lg">
            <div class="flex items-center mb-3">
              <div class="w-10 h-10 rounded-full bg-purple-900 flex items-center justify-center mr-3">
                <i class="material-icons text-purple-400">lightbulb</i>
              </div>
              <h3 class="font-semibold text-lg">Revelation</h3>
            </div>
            <p class="text-gray-400 text-sm leading-relaxed">Plot twists and discoveries</p>
          </div>
          <div class="group bg-gray-800 rounded-xl p-5 border-l-4 border-pink-500 hover:border-pink-400 transition-all hover:bg-gray-750 hover:shadow-lg">
            <div class="flex items-center mb-3">
              <div class="w-10 h-10 rounded-full bg-pink-900 flex items-center justify-center mr-3">
                <i class="material-icons text-pink-400">autorenew</i>
              </div>
              <h3 class="font-semibold text-lg">Transformation</h3>
            </div>
            <p class="text-gray-400 text-sm leading-relaxed">Character growth and change</p>
          </div>
          <div class="group bg-gradient-to-br from-amber-900 to-orange-900 rounded-xl p-5 border-l-4 border-amber-400 hover:border-amber-300 transition-all hover:shadow-lg hover:shadow-amber-900">
            <div class="flex items-center mb-3">
              <div class="w-10 h-10 rounded-full bg-amber-800 flex items-center justify-center mr-3">
                <i class="material-icons text-amber-400">whatshot</i>
              </div>
              <h3 class="font-semibold text-lg text-amber-100">Climax</h3>
            </div>
            <p class="text-amber-200 text-sm leading-relaxed">The peak of tension and action</p>
          </div>
        </div>
      </div>

      <%# Resolution %>
      <div>
        <div class="flex items-center mb-4">
          <div class="h-px flex-grow bg-gradient-to-r from-transparent to-teal-500"></div>
          <span class="px-4 text-teal-400 font-medium uppercase tracking-wider text-sm">Resolution</span>
          <div class="h-px flex-grow bg-gradient-to-l from-transparent to-teal-500"></div>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 max-w-2xl mx-auto">
          <div class="group bg-gray-800 rounded-xl p-5 border-l-4 border-teal-500 hover:border-teal-400 transition-all hover:bg-gray-750 hover:shadow-lg">
            <div class="flex items-center mb-3">
              <div class="w-10 h-10 rounded-full bg-teal-900 flex items-center justify-center mr-3">
                <i class="material-icons text-teal-400">check_circle</i>
              </div>
              <h3 class="font-semibold text-lg">Resolution</h3>
            </div>
            <p class="text-gray-400 text-sm leading-relaxed">Conflict resolved, story concludes</p>
          </div>
          <div class="group bg-gray-800 rounded-xl p-5 border-l-4 border-cyan-500 hover:border-cyan-400 transition-all hover:bg-gray-750 hover:shadow-lg">
            <div class="flex items-center mb-3">
              <div class="w-10 h-10 rounded-full bg-cyan-900 flex items-center justify-center mr-3">
                <i class="material-icons text-cyan-400">history</i>
              </div>
              <h3 class="font-semibold text-lg">Aftermath</h3>
            </div>
            <p class="text-gray-400 text-sm leading-relaxed">Life after the main events</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<%# ========== SECTION 5: TIMELINE EVENTS STRUCTURE ========== %>
<section class="text-gray-600 dark:text-gray-300 body-font">
  <div class="container flex flex-wrap px-5 py-20 mx-auto items-center">
    <div class="md:w-2/5 md:pr-12 md:py-8 md:border-r md:border-b-0 mb-10 md:mb-0 pb-10 border-b border-gray-200 dark:border-gray-700">
      <h1 class="sm:text-3xl text-2xl font-medium title-font mb-4 text-gray-900 dark:text-white">
        <i class="material-icons <%= @content_type.text_color %> text-6xl float-left mr-4">
          <%= @content_type.icon %>
        </i>

        Build your story
        <span class="<%= @content_type.text_color %>">event by event</span>
      </h1>
      <p class="leading-relaxed text-base my-2">
        Unlike other worldbuilding pages, Timelines are structured around <strong>events</strong> that happen
        at specific points in time. Each event can have a name, description, date, and links to other pages
        in your notebook.
      </p>
      <p class="leading-relaxed text-base my-2">
        This makes Timelines perfect for tracking plot points, historical events, character arcs, and anything
        else that unfolds over time in your world.
      </p>
    </div>
    <div class="flex flex-col md:w-3/5 md:pl-12">
      <div class="w-full bg-white dark:bg-gray-800 mx-auto border border-gray-200 dark:border-gray-700 rounded-lg overflow-hidden">
        <div class="p-6">
          <h3 class="text-lg font-medium text-gray-900 dark:text-white mb-4">
            <i class="material-icons <%= @content_type.text_color %> mr-2">event</i>
            Timeline Events
          </h3>
          <p class="text-base mb-4">
            Each timeline consists of events that you can customize with:
          </p>
          <ul class="space-y-3">
            <li class="flex items-start">
              <i class="material-icons text-green-500 mr-2 text-sm">check_circle</i>
              <span><strong>Event name</strong> &mdash; Give each event a memorable title</span>
            </li>
            <li class="flex items-start">
              <i class="material-icons text-green-500 mr-2 text-sm">check_circle</i>
              <span><strong>Description</strong> &mdash; Add as much detail as you need</span>
            </li>
            <li class="flex items-start">
              <i class="material-icons text-green-500 mr-2 text-sm">check_circle</i>
              <span><strong>Date tracking</strong> &mdash; Use real or fictional calendar systems</span>
            </li>
            <li class="flex items-start">
              <i class="material-icons text-green-500 mr-2 text-sm">check_circle</i>
              <span><strong>Duration</strong> &mdash; Track start and end times for events</span>
            </li>
            <li class="flex items-start">
              <i class="material-icons text-green-500 mr-2 text-sm">check_circle</i>
              <span><strong>Event type</strong> &mdash; Categorize by narrative purpose</span>
            </li>
            <li class="flex items-start">
              <i class="material-icons text-green-500 mr-2 text-sm">check_circle</i>
              <span><strong>Page links</strong> &mdash; Connect events to characters, locations, and more</span>
            </li>
          </ul>
        </div>
      </div>
    </div>
  </div>
</section>

<%# ========== SECTION 6: WORLDBUILDING INTEGRATION ========== %>
<section class="text-gray-600 dark:text-gray-300 body-font bg-gradient-to-br from-green-50 to-emerald-50 dark:from-gray-900 dark:to-gray-800">
  <div class="container px-5 py-20 mx-auto">
    <div class="text-center mb-12">
      <h1 class="sm:text-4xl text-3xl font-medium title-font mb-4 text-gray-900 dark:text-white">
        Connect Events to
        <span class="<%= @content_type.text_color %>">Your Entire World</span>
      </h1>
      <p class="text-gray-600 dark:text-gray-400 lg:w-2/3 mx-auto leading-relaxed text-lg">
        Link characters, locations, items, and any other worldbuilding page directly to timeline events.
        Build a rich, interconnected narrative web.
      </p>
    </div>

    <div class="flex flex-wrap items-center">
      <div class="lg:w-1/2 w-full mb-10 lg:mb-0 lg:pr-12">
        <div class="bg-white dark:bg-gray-800 rounded-lg shadow-lg border border-green-200 dark:border-gray-700 p-6">
          <h3 class="text-lg font-medium text-gray-900 dark:text-white mb-4">
            <i class="material-icons <%= @content_type.text_color %> mr-2 align-middle"><%= @content_type.icon %></i>
            Link Any Page to Events
          </h3>
          <ul class="space-y-3">
            <li class="flex items-start">
              <i class="material-icons text-green-500 mr-2 text-sm mt-1">check_circle</i>
              <span><strong>Link characters</strong> &mdash; Track character arcs and appearances across your story</span>
            </li>
            <li class="flex items-start">
              <i class="material-icons text-green-500 mr-2 text-sm mt-1">check_circle</i>
              <span><strong>Connect locations</strong> &mdash; See where each event takes place</span>
            </li>
            <li class="flex items-start">
              <i class="material-icons text-green-500 mr-2 text-sm mt-1">check_circle</i>
              <span><strong>Reference items</strong> &mdash; Track when important objects appear in your story</span>
            </li>
            <li class="flex items-start">
              <i class="material-icons text-green-500 mr-2 text-sm mt-1">check_circle</i>
              <span><strong>Link creatures</strong> &mdash; Document when monsters and beings are encountered</span>
            </li>
            <li class="flex items-start">
              <i class="material-icons text-green-500 mr-2 text-sm mt-1">check_circle</i>
              <span><strong>Any page type</strong> &mdash; Connect 30+ worldbuilding page types to events</span>
            </li>
          </ul>
        </div>
      </div>
      <div class="lg:w-1/2 w-full">
        <div class="text-center lg:text-left">
          <div class="inline-flex flex-wrap gap-4 justify-center lg:justify-start">
            <div class="flex items-center bg-white dark:bg-gray-800 rounded-lg px-4 py-2 shadow-sm border border-gray-200 dark:border-gray-700">
