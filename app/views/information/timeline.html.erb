          <% next if content_type == Timeline %>
          <%= link_to send("#{content_type.name.downcase}_worldbuilding_info_path"), class: "tooltipped inline-block", data: { tooltip: content_type.name.pluralize } do %>
            <i class="material-icons <%= content_type.text_color %> text-5xl m-2 hover:scale-110 transition-transform"><%= content_type.icon %></i>
          <% end %>
        <% end %>
      </div>
      <div class="mt-12 mb-4">
        <%= link_to "Start worldbuilding now", new_user_registration_path, class: "#{@content_type.color} text-white py-3 px-8 hover:shadow-lg rounded-lg font-medium inline-block" %>
      </div>
      <p class="text-gray-500 dark:text-gray-400">
