              <strong class="text-gray-900 dark:text-white">Smart Adjustments</strong>
              <p class="text-gray-500 dark:text-gray-400">Fell behind? We'll recalculate your daily target based on remaining days. Got ahead? Celebrate with easier days.</p>
            </div>
          </li>
        </ul>
      </div>
      <div class="lg:w-1/2 w-full lg:pl-12">
        <div class="bg-white dark:bg-gray-800 rounded-lg shadow-lg border border-gray-200 dark:border-gray-700 p-6">
          <div class="flex items-center justify-between mb-6">
            <h3 class="text-lg font-medium text-gray-900 dark:text-white">
              <i class="material-icons text-emerald-500 mr-2 align-middle">flag</i>
              Writing Goal
            </h3>
            <span class="bg-emerald-100 dark:bg-emerald-900 text-emerald-800 dark:text-emerald-200 text-xs font-medium px-2 py-1 rounded">Active</span>
          </div>
          <div class="mb-6">
            <div class="flex justify-between text-sm mb-2">
              <span class="text-gray-500 dark:text-gray-400">Progress</span>
              <span class="text-emerald-600 dark:text-emerald-400 font-medium">24,500 / 50,000 words</span>
            </div>
            <div class="w-full bg-gray-200 dark:bg-gray-700 rounded-full h-3">
              <div class="bg-emerald-500 h-3 rounded-full" style="width: 49%;"></div>
            </div>
            <div class="flex justify-between text-xs mt-1 text-gray-400">
              <span>49% complete</span>
              <span>25,500 words remaining</span>
            </div>
          </div>
          <div class="grid grid-cols-3 gap-4 text-center">
            <div class="bg-gray-50 dark:bg-gray-900 rounded-lg p-3">
              <div class="text-2xl font-bold text-emerald-600 dark:text-emerald-400">1,275</div>
              <div class="text-xs text-gray-500 dark:text-gray-400">words/day needed</div>
            </div>
            <div class="bg-gray-50 dark:bg-gray-900 rounded-lg p-3">
              <div class="text-2xl font-bold text-emerald-600 dark:text-emerald-400">20</div>
              <div class="text-xs text-gray-500 dark:text-gray-400">days remaining</div>
            </div>
            <div class="bg-gray-50 dark:bg-gray-900 rounded-lg p-3">
              <div class="text-2xl font-bold text-emerald-600 dark:text-emerald-400">7</div>
              <div class="text-xs text-gray-500 dark:text-gray-400">day streak</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

