<%# ========== SECTION 1: HERO (Enhanced - 40vh) ========== %>
<section class="text-green-900" style="height: 40vh;">
  <div class="h-full bg-right-bottom bg-cover flex shadow-lg bg-gradient-to-r from-emerald-600 to-emerald-800">
    <div class="container mx-auto p-4 flex items-center z-10">
      <div class="text-center w-full">
        <div class="text-white tracking-widest py-4 px-5 my-5">
          <div class="mb-3 text-4xl md:text-6xl" style="text-shadow: black 0px 0px 10px;">
            <i class="material-icons text-5xl <%= @content_type.text_color %>"><%= @content_type.icon %></i>
            Write Your Book, Your Way
          </div>
          <div class="leading-normal text-xl md:text-2xl" style="text-shadow: black 0px 0px 10px;">
            Organize chapters, track progress, and bring your worldbuilding to life
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<%# ========== SECTION 2: VALUE PROPOSITION ========== %>
<section class="text-gray-600 dark:text-gray-300 body-font">
  <div class="container mx-auto flex px-5 py-16 md:flex-row flex-col items-center">
    <div class="lg:max-w-lg lg:w-full md:w-1/2 w-5/6 mb-10 md:mb-0">
      <div class="bg-gradient-to-br from-emerald-500 to-emerald-700 rounded-lg p-8 flex items-center justify-center h-64">
        <i class="material-icons text-white text-9xl"><%= @content_type.icon %></i>
      </div>
    </div>
    <div class="lg:flex-grow md:w-1/2 lg:pl-24 md:pl-16 flex flex-col md:items-start md:text-left items-center text-center">
      <h1 class="title-font sm:text-4xl text-3xl mb-4 font-medium text-gray-900 dark:text-white">
        The Writing Tool That
        <span class="<%= @content_type.text_color %>">Grows With Your Story</span>
      </h1>
      <p class="bg-emerald-50 dark:bg-emerald-900 py-4 px-4 my-2 rounded border border-emerald-200 dark:border-emerald-700">
        <em>
          Whether you're writing your first short story or your tenth novel, Notebook.ai's Books feature
          gives you everything you need to organize your writing and track your progress.
        </em>
      </p>
      <ul class="my-4 space-y-2">
        <li class="flex items-center">
          <i class="material-icons text-emerald-500 mr-2">check_circle</i>
          <span><strong>Unlimited free books</strong> &mdash; no credit card required</span>
        </li>
        <li class="flex items-center">
          <i class="material-icons text-emerald-500 mr-2">check_circle</i>
          <span><strong>Drag-and-drop chapter organization</strong> &mdash; reorder effortlessly</span>
        </li>
        <li class="flex items-center">
          <i class="material-icons text-emerald-500 mr-2">check_circle</i>
          <span><strong>Real-time progress tracking</strong> &mdash; word counts, pages, reading time</span>
        </li>
      </ul>
    </div>
  </div>
</section>

<%# ========== SECTION 3: CORE FEATURES (3 Cards) ========== %>
<section class="text-gray-600 dark:text-gray-300 body-font bg-gray-50 dark:bg-gray-900">
  <div class="container px-5 py-16 mx-auto">
