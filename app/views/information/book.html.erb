            <i class="material-icons text-emerald-400 mr-3">menu_book</i>
            <h3 class="text-lg font-medium">Estimated Pages</h3>
          </div>
          <p class="text-gray-400">
            See your book's estimated page count based on standard publishing metrics.
            Know how thick your book will be.
          </p>
        </div>
      </div>
      <div class="p-4 md:w-1/2 lg:w-1/3">
        <div class="bg-gray-800 border border-emerald-600 rounded-lg p-6 h-full">
          <div class="flex items-center mb-4">
            <i class="material-icons text-emerald-400 mr-3">schedule</i>
            <h3 class="text-lg font-medium">Reading Time</h3>
          </div>
          <p class="text-gray-400">
            Estimate how long it takes to read your book based on average reading speeds.
