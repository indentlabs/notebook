          <div class="w-20 h-20 md:mt-4 inline-flex items-center justify-center rounded-full bg-emerald-100 dark:bg-emerald-900 mb-5 flex-shrink-0">
            <i class="material-icons text-emerald-600 dark:text-emerald-400 text-5xl">analytics</i>
          </div>
          <div class="flex-grow text-left px-4">
            <h2 class="text-gray-900 dark:text-white text-lg title-font font-medium mb-3">
              Track Every Word
            </h2>
            <p class="leading-relaxed text-base my-2">
              Watch your word count grow in real-time. See estimated page counts, reading time, and
              track your progress toward your goals.
            </p>
            <p class="leading-relaxed text-base my-2 bg-emerald-50 dark:bg-emerald-900 py-2 px-4 -mx-4 my-4 border border-emerald-100 dark:border-emerald-800 rounded">
              Know instantly whether you're writing a short story, novella, or epic novel.
            </p>
          </div>
        </div>
      </div>
      <div class="p-8 lg:w-1/3 flex flex-col items-center">
        <div class="bg-white dark:bg-gray-800 border border-emerald-100 dark:border-gray-700 rounded-lg p-4 text-center h-full shadow-sm">
          <div class="w-20 h-20 md:mt-4 inline-flex items-center justify-center rounded-full bg-emerald-100 dark:bg-emerald-900 mb-5 flex-shrink-0">
            <i class="material-icons text-emerald-600 dark:text-emerald-400 text-5xl">star</i>
          </div>
          <div class="flex-grow text-left px-4">
            <h2 class="text-gray-900 dark:text-white text-lg title-font font-medium mb-3">
              Free Forever
            </h2>
            <p class="leading-relaxed text-base my-2">
              Create unlimited books on Notebook.ai without ever paying a dime. No credit card required,
              no trial period, no catch.
            </p>
            <p class="leading-relaxed text-base my-2 bg-emerald-50 dark:bg-emerald-900 py-2 px-4 -mx-4 my-4 border border-emerald-100 dark:border-emerald-800 rounded">
              Your books are yours forever &mdash; we'll never lock you out of your own writing.
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<%# ========== SECTION 4: ANALYTICS SHOWCASE ========== %>
<section class="text-white body-font bg-gray-900">
